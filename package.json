{
  "name": "micronaut-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "npm run typecheck && npm run typecheck:scripts && npm run style:scripts && npm run test:asciidoc && npm run test:docs && npm run test:guides && npm run test:main-site && npm run test:deployment && node scripts/validate-docs-snippet-style-sharing.ts",
    "snippet-styles": "node scripts/validate-docs-snippet-style-sharing.ts",
    "sync:docs-projects": "node scripts/sync-docs-fixture.ts",
    "sync:main-site-content": "node scripts/sync-main-site-content.ts && npm run normalize:main-site-markdown",
    "normalize:main-site-markdown": "node scripts/normalize-main-site-markdown.ts",
    "extract:main-site-resources": "node scripts/extract-main-site-resources.ts",
    "extract:inline-assets": "node scripts/extract-inline-assets.ts",
    "render:docs": "node scripts/render-docs.ts",
    "render:guides": "node scripts/render-guides.ts",
    "prepare:generated-docs": "npm run render:docs",
    "prepare:generated-content": "node scripts/prepare-generated-content.ts",
    "test:main-site": "node --test scripts/tests/main-site/*.test.ts && node scripts/run-main-site-browser-tests.ts",
    "test:main-site:browser": "playwright test --config playwright.config.ts tests/playwright/main-site.spec.ts",
    "test:asciidoc": "node --test scripts/tests/asciidoc/*.test.ts",
    "test:docs": "node --test scripts/tests/docs/*.test.ts && node scripts/run-docs-browser-tests.ts",
    "test:docs:browser": "node scripts/prepare-playwright-generated-content.ts docs && playwright test --config playwright.config.ts tests/playwright/docs.spec.ts",
    "test:guides": "node --test scripts/tests/guides/*.test.ts && node scripts/run-guides-browser-tests.ts",
    "test:guides:browser": "node scripts/prepare-playwright-generated-content.ts guides && playwright test --config playwright.config.ts tests/playwright/guides.spec.ts",
    "test:deployment": "node --test scripts/tests/deployment/*.test.ts",
    "typecheck": "tsc --noEmit --pretty false",
    "typecheck:scripts": "tsc --project tsconfig.scripts.json --noEmit --pretty false",
    "style:scripts": "prettier --check \"scripts/**/*.ts\"",
    "dev": "npm run check && npm run prepare:generated-content && astro dev --host 127.0.0.1",
    "build:site": "npm run check && npm run prepare:generated-content && astro build && node scripts/build-site-header-shell.ts && npm run extract:inline-assets && node scripts/prepare-template-artifacts.ts",
    "build": "npm run check && npm run prepare:generated-content && astro build && node scripts/build-site-header-shell.ts && npm run extract:inline-assets && node scripts/prepare-template-artifacts.ts",
    "build:surface": "node scripts/build-surface.ts",
    "build:main": "node scripts/build-surface.ts --surface main",
    "build:docs": "node scripts/build-surface.ts --surface docs",
    "build:guides": "node scripts/build-surface.ts --surface guides",
    "prune:surface": "node scripts/prune-surface.ts",
    "update:docs-versions": "node scripts/update-docs-version-manifest.ts",
    "publish:docs-surface": "node scripts/publish-docs-surface.ts",
    "preview": "astro preview --host 127.0.0.1"
  },
  "dependencies": {
    "@asciidoctor/core": "4.0.0-alpha.5",
    "@astrojs/react": "5.0.5",
    "@shikijs/core": "4.1.0",
    "@shikijs/engine-javascript": "4.1.0",
    "@shikijs/langs": "4.1.0",
    "@shikijs/themes": "4.1.0",
    "asciidoctor": "4.0.0-alpha.5",
    "astro": "6.3.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "2.1.1",
    "cmdk": "^1.1.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.16.0",
    "parse5": "^7.3.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "shiki": "^4.1.0",
    "smol-toml": "^1.6.1",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "prettier": "^3.8.3",
    "typescript": "6.0.3"
  },
  "overrides": {
    "vite": "^7.0.0"
  }
}
