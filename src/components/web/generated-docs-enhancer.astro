} from "@/components/web/docs-snippet-icons";
import { CopyIcon } from "@/components/web/docs-snippet-card";
import { renderDocsSnippetTemplates } from "@/components/web/docs-snippet-templates";

const docsSnippetTemplates = Object.fromEntries(
  Object.entries(renderDocsSnippetTemplates()).filter(([name]) => name !== "docs/snippets/properties-snippet.html")
);
const copyButtonIconHtml = renderToStaticMarkup(createElement(CopyIcon));
