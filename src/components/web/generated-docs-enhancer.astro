        const panels = template?.querySelector(":scope > [data-slot='card-content']");
        const tabs = template?.querySelector(".docs-snippet-tabs");
        const copyButton = template?.querySelector("[data-copy-active-snippet]");
        if (!template || !panels || !tabs || !copyButton) {
          continue;
        }
        decorateCopyButtonIcon(copyButton);
        let activeIndex = 0;

        const activate = (nextIndex) => {
          activeIndex = nextIndex;
          group.forEach((panel, index) => {
            const active = index === activeIndex;
            panel.hidden = !active;
            panel.setAttribute("aria-hidden", String(!active));
          });
          tabs.querySelectorAll("button").forEach((button, index) => {
            const active = index === activeIndex;
            button.setAttribute("aria-selected", String(active));
            button.tabIndex = active ? 0 : -1;
            decorateLanguageButton(button, active);
          });
        };

        group.forEach((panel, index) => {
          const language = panel.dataset.lang || panel.querySelector("code")?.dataset.lang || "code";
          const tabId = `docs-snippet-tab-${groupIndex}-${index}`;
          const panelId = `docs-snippet-panel-${groupIndex}-${index}`;
          const tab = document.createElement("button");
          decorateLanguageButton(tab, index === 0);
          tab.type = "button";
          tab.id = tabId;
          tab.dataset.lang = codeLanguageKey(language);
          tab.setAttribute("role", "tab");
          tab.setAttribute("aria-controls", panelId);
          tab.innerHTML = codeLanguageTabHtml(language, formatLanguage(language));
          tab.addEventListener("click", () => activate(index));
          tab.addEventListener("keydown", (event) => {
            if (event.key !== "ArrowRight" && event.key !== "ArrowLeft") {
              return;
            }
            event.preventDefault();
            const offset = event.key === "ArrowRight" ? 1 : -1;
            const nextIndex = (index + offset + group.length) % group.length;
            activate(nextIndex);
            tabs.querySelectorAll("button")[nextIndex].focus();
          });
          tabs.append(tab);

          panel.id = panelId;
          panel.setAttribute("role", "tabpanel");
          panel.setAttribute("aria-labelledby", tabId);
          panel.removeAttribute("data-slot");
          panel.querySelector(":scope > .docs-code-copy")?.remove();
          const renderedContent = panel.querySelector(":scope > [data-slot='card-content'], :scope > .content");
          if (renderedContent) {
            while (renderedContent.firstChild) {
              panel.append(renderedContent.firstChild);
            }
            renderedContent.remove();
          }
          panel.className = panelClass;
          decorateCodeSurface(panel);
        });

        bindCopyButton(copyButton, () => snippetText(group[activeIndex]));

        const intro = makeExternalSnippetIntro(titleHtml, descriptionHtml, dependency);
        if (intro) {
          originalParent.insertBefore(intro, referenceNode);
        }
        originalParent.insertBefore(template, referenceNode);
        group.forEach((panel) => panels.append(panel));
        if (hasCallouts) {
          template.append(afterGroup);
        }
        activate(0);
        groupIndex += 1;
      }
    };

    const enhanceTemplateSnippetControls = (root) => {
      root.querySelectorAll(".docs-snippet-tabs .language-option, .docs-code-tabs .language-option").forEach((option) => {
        enhanceLanguageOptionIcon(option);
      });

      root.querySelectorAll(".docs-snippet-template").forEach((template) => {
        bindStaticSnippetTemplate(template);
        const heading = template.querySelector(":scope .docs-snippet-heading");
        if (heading && !heading.querySelector(".docs-code-language-icon")) {
          heading.insertAdjacentHTML("afterbegin", snippetKindIcon(template.dataset.snippetKind || "code"));
        }
      });

      root.querySelectorAll(".docs-properties-heading").forEach((heading) => {
        if (!heading.querySelector(".docs-code-language-icon")) {
          heading.insertAdjacentHTML("afterbegin", snippetKindIcon("properties"));
        }
      });
    };

    const stabilizeGeneratedImages = (root) => {
      root.querySelectorAll("img").forEach((image) => {
        image.loading = image.loading || "lazy";
        image.decoding = image.decoding || "async";
        const applyDimensions = () => {
          if (image.naturalWidth > 0 && image.naturalHeight > 0) {
            image.width = image.width || image.naturalWidth;
            image.height = image.height || image.naturalHeight;
          }
        };
        if (image.complete) {
          applyDimensions();
        } else {
          image.addEventListener("load", applyDimensions, { once: true });
        }
      });
    };

    const init = () => {
      document.querySelectorAll("[data-generated-docs]").forEach((root) => {
        if (root.dataset.generatedDocsEnhanced === "true") {
          return;
        }
        root.dataset.generatedDocsEnhanced = "true";
        stabilizeGeneratedImages(root);
        enhanceStandaloneCodeBlocks(root);
        enhanceCodeSnippets(root);
        enhanceTemplateSnippetControls(root);
        decorateCodeSurface(root);
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init, { once: true });
    } else {
      init();
    }
  })();
</script>
