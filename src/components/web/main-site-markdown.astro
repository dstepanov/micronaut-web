---
type Props = {
  html?: string;
};

const { html = "" } = Astro.props;
---

{html && <div class="main-site-markdown" set:html={html} />}

<style>
  .main-site-markdown {
    margin-top: 2.25rem;
    color: var(--foreground);
    font-size: 1rem;
    line-height: 1.8;
  }

  .main-site-markdown :global(> :first-child) {
    margin-top: 0;
  }

  .main-site-markdown :global(> :last-child) {
    margin-bottom: 0;
  }

  .main-site-markdown :global(h1),
  .main-site-markdown :global(h2),
  .main-site-markdown :global(h3),
  .main-site-markdown :global(h4),
  .main-site-markdown :global(h5),
  .main-site-markdown :global(h6) {
    scroll-margin-top: 6rem;
    color: var(--foreground);
    font-weight: 700;
    line-height: 1.22;
  }

  .main-site-markdown :global(h1) {
    margin-top: 2.5rem;
    font-size: 2rem;
  }

  .main-site-markdown :global(h2) {
    margin-top: 2.75rem;
    border-top: 1px solid var(--border);
    padding-top: 2.25rem;
    font-size: 1.65rem;
  }

  .main-site-markdown :global(h3) {
    margin-top: 2.25rem;
    font-size: 1.3rem;
  }

  .main-site-markdown :global(h4) {
    margin-top: 1.75rem;
    font-size: 1.1rem;
  }

  .main-site-markdown :global(h5),
  .main-site-markdown :global(h6) {
    margin-top: 1.5rem;
    font-size: 1rem;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  .main-site-markdown :global(p) {
    margin-top: 1rem;
    font-size: 1rem;
    line-height: 1.85rem;
    color: var(--muted-foreground);
  }

  .main-site-markdown :global(p:has(> strong:only-child)) {
    margin-top: 1.65rem;
    color: var(--foreground);
    font-size: 1.08rem;
    line-height: 1.45;
  }

  .main-site-markdown :global(strong) {
    color: var(--foreground);
    font-weight: 700;
  }

  .main-site-markdown :global(em) {
    color: var(--foreground);
  }

  .main-site-markdown :global(ul),
  .main-site-markdown :global(ol) {
    margin-top: 1.25rem;
    padding-left: 1.6rem;
    font-size: 1rem;
    line-height: 1.8rem;
    color: var(--muted-foreground);
  }

  .main-site-markdown :global(ul) {
    list-style: disc;
  }

  .main-site-markdown :global(ol) {
    list-style: decimal;
  }

  .main-site-markdown :global(li) {
    margin-top: 0.5rem;
    padding-left: 0.25rem;
  }

  .main-site-markdown :global(li::marker) {
    color: var(--brand);
    font-weight: 700;
  }

  .main-site-markdown :global(li > ul),
  .main-site-markdown :global(li > ol) {
    margin-top: 0.5rem;
  }

  .main-site-markdown :global(a) {
    font-size: inherit;
    font-weight: 600;
    color: var(--brand);
    text-decoration: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 4px;
    overflow-wrap: anywhere;
  }

  .main-site-markdown :global(a:hover) {
    color: var(--brand-hover);
  }

  .main-site-markdown :global(code:not(pre code)) {
    border: 1px solid var(--border);
    border-radius: 0.35rem;
    background: var(--muted);
    padding: 0.1rem 0.32rem;
    color: var(--foreground);
    font-size: 0.9em;
    line-height: 1.4;
  }

  .main-site-markdown :global(pre) {
    position: relative;
    margin-top: 1.4rem;
    margin-bottom: 1.6rem;
    overflow-x: auto;
    border-radius: 0.5rem;
    border: 1px solid var(--border);
    padding: 1.1rem;
    font-size: 0.875rem;
    line-height: 1.6rem;
  }

  .main-site-markdown :global(pre[data-lang]:not([data-lang=""]):not([data-lang="text"])::before) {
    content: attr(data-lang);
    position: sticky;
    left: 0;
    display: block;
    width: fit-content;
    margin-bottom: 0.75rem;
    border: 1px solid rgba(230, 230, 230, 0.6);
    border-radius: 999px;
    background: #fcfcfc;
    padding: 0.1rem 0.55rem;
    color: #666666;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    line-height: 1.2rem;
    text-transform: uppercase;
  }

  .main-site-markdown :global(pre code) {
    display: grid;
    min-width: max-content;
    background: transparent;
    color: inherit;
    font-family: var(--font-mono);
    font-size: inherit;
    line-height: inherit;
  }

  .main-site-markdown :global(.shiki) {
    border-color: rgba(230, 230, 230, 0.6) !important;
    background-color: var(--shiki-light-bg, #ffffff) !important;
    color: var(--shiki-light, #1f2328) !important;
  }

  :global(.dark) .main-site-markdown :global(.shiki) {
    border-color: #30363d !important;
    background-color: var(--shiki-dark-bg, #0d1117) !important;
    color: var(--shiki-dark, #e6edf3) !important;
  }

  :global(.dark) .main-site-markdown :global(.shiki span[style]) {
    color: var(--shiki-dark, var(--shiki-light, currentColor)) !important;
    font-style: var(--shiki-dark-font-style, var(--shiki-light-font-style, inherit)) !important;
    font-weight: var(--shiki-dark-font-weight, var(--shiki-light-font-weight, inherit)) !important;
    text-decoration: var(--shiki-dark-text-decoration, var(--shiki-light-text-decoration, inherit)) !important;
  }

  .main-site-markdown :global(blockquote) {
    margin-top: 1.5rem;
    border-left: 4px solid var(--brand);
    padding: 0.15rem 0 0.15rem 1.2rem;
    color: var(--foreground);
  }

  .main-site-markdown :global(blockquote p) {
    color: var(--foreground);
  }

  .main-site-markdown :global(hr) {
    margin: 2.25rem 0;
    border: 0;
    border-top: 1px solid var(--border);
  }

  .main-site-markdown :global(img) {
    margin-top: 1.5rem;
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
    border: 1px solid var(--border);
  }

  .main-site-markdown :global(table) {
    margin-top: 1.5rem;
    display: block;
    width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
    font-size: 0.94rem;
  }

  .main-site-markdown :global(th),
  .main-site-markdown :global(td) {
    border: 1px solid var(--border);
    padding: 0.65rem 0.8rem;
    text-align: left;
    vertical-align: top;
  }

  .main-site-markdown :global(th) {
    background: var(--muted);
    color: var(--foreground);
    font-weight: 700;
  }

  .main-site-markdown :global(td) {
    color: var(--muted-foreground);
  }

  @media (min-width: 768px) {
    .main-site-markdown :global(h1) {
      font-size: 3rem;
    }

    .main-site-markdown :global(h2) {
      font-size: 2.15rem;
    }

    .main-site-markdown :global(h3) {
      font-size: 1.55rem;
    }
  }
</style>
