---
import { Badge } from "@/components/ui/badge";
import { Button, buttonVariants } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { LatestGuideCard } from "@/components/web/latest-guide-card";
import { latestGuides, type GeneratedGuide } from "@/lib/generated-guides";
import { withBasePath } from "@/lib/base-path";
import guidesVersions from "@/data/guides-versions.json";

type Props = {
  guides: GeneratedGuide[];
  activeTag?: string;
  root?: string;
};

type SortMode = "latest" | "title" | "duration";

const { guides, activeTag, root = "/latest" } = Astro.props;
const searchParams = Astro.url.searchParams;
const query = (searchParams.get("q") || "").trim();
const selectedCategory = (searchParams.get("category") || "").trim();
const selectedTag = activeTag || (searchParams.get("tag") || "").trim();
const sortParam = (searchParams.get("sort") || "latest").trim();
const sortMode: SortMode = sortParam === "title" || sortParam === "duration" ? sortParam : "latest";
const rootPath = `${root.replace(/\/+$/, "")}/`;
const categories = Array.from(new Set(guides.flatMap((guide) => guide.categories))).sort((left, right) => left.localeCompare(right));
const tags = Array.from(new Set(guides.flatMap((guide) => guide.tags))).sort((left, right) => left.localeCompare(right));
const categoryCounts = categories
  .map((category) => ({
    label: category,
    slug: categorySlug(category),
    count: guides.filter((guide) => guide.categories.includes(category)).length
  }))
  .sort((left, right) => right.count - left.count || left.label.localeCompare(right.label));
const languageCounts = sortedOptionCounts(guides, (option) => option.languageLabel);
const buildToolCounts = sortedOptionCounts(guides, (option) => option.buildToolLabel);
const minutes = guides.map((guide) => guide.estimatedMinutes).filter((minute) => minute > 0).sort((left, right) => left - right);
const medianMinutes = minutes.length ? minutes[Math.floor((minutes.length - 1) / 2)] : 0;
const topCategoryLabels = categoryCounts.slice(0, 6).map((category) => category.label);
const guideContentSummary = topCategoryLabels.length
  ? `Follow focused tutorials across ${formatList(topCategoryLabels)}.`
  : "Follow focused tutorials generated from guide metadata.";
const contentStats = [
  {
    value: guides.length.toLocaleString(),
    label: "Runnable guides",
    copy: `${guides.reduce((total, guide) => total + guide.options.length, 0).toLocaleString()} generated language/build variants`
  },
  {
    value: categories.length.toLocaleString(),
    label: "Topics",
    copy: categoryCounts.slice(0, 3).map((category) => category.label).join(", ") || "Generated from guide metadata"
  },
  {
    value: languageCounts.length.toLocaleString(),
    label: "Languages",
    copy: languageCounts.slice(0, 3).map((language) => `${language.label} (${language.count})`).join(", ") || "Guide variants"
  },
  {
    value: medianMinutes ? `${medianMinutes} min` : "Ready",
    label: "Typical guide",
    copy: buildToolCounts.slice(0, 3).map((tool) => `${tool.label} (${tool.count})`).join(", ") || "Runnable project paths"
  }
];
const visibleGuides = sortGuides(
  guides.filter((guide) =>
    matchesQuery(guide, query) &&
    matchesCategory(guide, selectedCategory) &&
    matchesTag(guide, selectedTag)
  ),
  sortMode
);
const categoryGroups = new Map<string, GeneratedGuide[]>();
for (const guide of visibleGuides) {
  const category = guide.categories[0] || "Guides";
  categoryGroups.set(category, [...(categoryGroups.get(category) || []), guide]);
}
const hasFilters = Boolean(query || selectedCategory || selectedTag || sortMode !== "latest");
const recentGuides = hasFilters ? [] : latestGuides(visibleGuides, 6);
const guideVersionOptions = guidesVersions.versions.map((version) => ({
  ...version,
  href: version.href.startsWith("http") ? version.href : withBasePath(version.current ? rootPath : version.href)
}));

function categorySlug(category: string) {
  return category
    .trim()
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

function matchesCategory(guide: GeneratedGuide, category: string) {
  if (!category) {
    return true;
  }
  return guide.categories.some((guideCategory) => guideCategory === category || categorySlug(guideCategory) === category);
}

function matchesTag(guide: GeneratedGuide, tag: string) {
  if (!tag) {
    return true;
  }
  return guide.tags.includes(tag);
}

function matchesQuery(guide: GeneratedGuide, value: string) {
  if (!value) {
    return true;
  }
  const normalized = value.toLowerCase();
  return [
    guide.title,
    guide.intro,
    guide.authors.join(" "),
    guide.categories.join(" "),
    guide.tags.join(" ")
  ].join(" ").toLowerCase().includes(normalized);
}

function sortGuides(items: GeneratedGuide[], mode: SortMode) {
  return [...items].sort((left, right) => {
    if (mode === "title") {
      return left.title.localeCompare(right.title);
    }
    if (mode === "duration") {
      return left.estimatedMinutes - right.estimatedMinutes || left.title.localeCompare(right.title);
    }
    return right.publicationDate.localeCompare(left.publicationDate) || left.title.localeCompare(right.title);
  });
}

function sortedOptionCounts(
  guides: GeneratedGuide[],
  labelForOption: (option: GeneratedGuide["options"][number]) => string
) {
  const counts = new Map<string, Set<string>>();
  for (const guide of guides) {
    for (const option of guide.options) {
      const label = labelForOption(option);
      if (!label) {
        continue;
      }
      let guideSlugs = counts.get(label);
      if (!guideSlugs) {
        guideSlugs = new Set<string>();
        counts.set(label, guideSlugs);
      }
      guideSlugs.add(guide.slug);
    }
  }
  return Array.from(counts.entries())
    .map(([label, guideSlugs]) => ({ label, count: guideSlugs.size }))
    .sort((left, right) => right.count - left.count || left.label.localeCompare(right.label));
}

function formatList(items: string[]) {
  if (items.length <= 1) {
    return items.join("");
  }
  if (items.length === 2) {
    return items.join(" and ");
  }
  return `${items.slice(0, -1).join(", ")}, and ${items[items.length - 1]}`;
}

function filterHref(next: Partial<{ q: string; category: string; tag: string; sort: SortMode }>) {
  const params = new URLSearchParams();
  const nextQuery = next.q ?? query;
  const nextCategory = next.category ?? selectedCategory;
  const nextTag = next.tag ?? selectedTag;
  const nextSort = next.sort ?? sortMode;
  if (nextQuery) {
    params.set("q", nextQuery);
  }
  if (nextCategory) {
    params.set("category", nextCategory);
  }
  if (nextTag) {
    params.set("tag", nextTag);
  }
  if (nextSort !== "latest") {
    params.set("sort", nextSort);
  }
  const suffix = params.toString();
  return withBasePath(`${rootPath}${suffix ? `?${suffix}` : ""}`);
}
---

<main class="mx-auto grid w-full max-w-[1320px] gap-8 px-4 py-8 md:px-6 lg:py-10" data-guides-catalog data-active-tag={activeTag || ""}>
  <header class="max-w-3xl">
    <div class="max-w-3xl">
      <Badge variant="secondary">{activeTag ? "Tag" : "Guides"}</Badge>
      <h1 class="mt-5 text-4xl font-bold tracking-tight md:text-5xl">
        {activeTag ? `Micronaut Guides: ${activeTag}` : "Micronaut Guides"}
      </h1>
      <p class="mt-4 text-lg leading-8 text-muted-foreground">
        Learn how to build Micronaut applications with focused tutorials, runnable examples, and language/build variants.
      </p>
      {guideVersionOptions.length > 1 && (
        <label class="mt-5 inline-grid gap-1 text-xs font-medium text-muted-foreground">
          <span>Guides version</span>
          <select
            class="h-9 min-w-44 rounded-md border bg-background px-2 text-sm text-foreground outline-none transition focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50"
            aria-label="Guides version"
            data-guides-version-selector
          >
            {guideVersionOptions.map((version) => (
              <option value={version.href} selected={version.current}>{version.label}</option>
            ))}
          </select>
        </label>
      )}
    </div>
  </header>

  {!activeTag && (
    <section
      class="grid gap-4 rounded-xl border bg-muted/30 p-4 md:p-5"
      aria-labelledby="guide-content-heading"
      data-guides-content-section
    >
      <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div class="max-w-3xl">
          <Badge variant="outline">Content</Badge>
          <h2 id="guide-content-heading" class="mt-3 text-2xl font-semibold tracking-tight">
            Guide content for common Micronaut workflows
          </h2>
          <p class="mt-2 text-sm leading-6 text-muted-foreground">{guideContentSummary}</p>
        </div>
        <a href="#guides-list" class={buttonVariants({ variant: "outline" })}>Browse all guides</a>
      </div>
      <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-4">
        {contentStats.map((stat) => (
          <div class="grid min-h-32 gap-2 rounded-lg border bg-card p-4">
            <div class="text-2xl font-semibold">{stat.value}</div>
            <h3 class="text-sm font-semibold">{stat.label}</h3>
            <p class="text-sm leading-6 text-muted-foreground">{stat.copy}</p>
          </div>
        ))}
      </div>
      {categoryCounts.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {categoryCounts.slice(0, 10).map((category) => (
            <a
              href={filterHref({ category: category.slug })}
              class="no-underline"
              aria-label={`Open guides in ${category.label}`}
            >
              <Badge variant="secondary">{category.label} · {category.count}</Badge>
            </a>
          ))}
        </div>
      )}
    </section>
  )}

  {!activeTag && recentGuides.length > 0 && (
    <section class="grid gap-4" data-guides-latest-section>
      <div class="flex items-center justify-between gap-4">
        <h2 class="text-2xl font-semibold tracking-tight">Latest Guides</h2>
      </div>
      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {recentGuides.map((guide) => <LatestGuideCard client:visible guide={guide} root={root} />)}
      </div>
    </section>
  )}

  {tags.length > 0 && (
    <section class="flex flex-wrap gap-2">
      {tags.slice(0, 80).map((tag) => (
        <a href={filterHref({ tag })} class="no-underline" aria-label={`Filter guides tagged ${tag}`}>
          <Badge variant={tag === selectedTag ? "default" : "outline"}>{tag}</Badge>
        </a>
      ))}
    </section>
  )}

  <section id="guides-list" class="grid gap-7">
    {Array.from(categoryGroups.entries()).map(([category, categoryGuides]) => (
      <div class="grid gap-4" data-guide-category-group>
        <h2 class="text-2xl font-semibold tracking-tight">{category}</h2>
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3" data-guide-card-grid>
          {categoryGuides.map((guide) => (
            <div
              data-guide-card
              data-title={guide.title}
              data-search={[guide.title, guide.intro, guide.authors.join(" "), guide.categories.join(" "), guide.tags.join(" ")].join(" ").toLowerCase()}
              data-categories={guide.categories.map(categorySlug).join("|")}
              data-tags={guide.tags.join("|")}
              data-date={guide.publicationDate}
              data-minutes={guide.estimatedMinutes}
            >
              <LatestGuideCard client:visible guide={guide} root={root} />
            </div>
          ))}
        </div>
      </div>
    ))}
  </section>

  <div data-guides-empty hidden={visibleGuides.length > 0}>
    <Card>
      <CardHeader>
        <CardTitle>No guides found</CardTitle>
        <CardDescription>The generated guide catalog does not contain entries for this filter.</CardDescription>
      </CardHeader>
      <CardContent>
        <Button asChild>
          <a href={withBasePath(`${root}/`)}>Open all guides</a>
        </Button>
      </CardContent>
    </Card>
  </div>
</main>

<script>
  import "@/scripts/guides-version-selector";
</script>
