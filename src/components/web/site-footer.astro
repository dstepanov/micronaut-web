---
import { Separator } from "@/components/ui/separator";
import { mainSiteFooterGroups } from "@/data/main-site-pages";
import { MicronautLogo } from "@/components/web/micronaut-logo";
---

<footer class="border-t bg-card">
  <div class="mx-auto grid max-w-[1200px] gap-8 px-4 py-10 md:px-6 lg:grid-cols-[minmax(0,1fr)_2fr]">
    <div>
      <a href="/" class="inline-flex items-center">
        <MicronautLogo />
      </a>
      <p class="mt-4 max-w-sm text-sm leading-6 text-muted-foreground">
        A modern, JVM-based framework for fast cloud applications.
      </p>
    </div>
    <nav class="grid gap-6 sm:grid-cols-2 lg:grid-cols-5" aria-label="Main site footer">
      {mainSiteFooterGroups.map((group) => (
        <div>
          <h2 class="text-sm font-semibold text-foreground">{group.title}</h2>
          <ul class="mt-3 grid gap-2">
            {group.links.map((link) => (
              <li>
                <a class="text-sm text-muted-foreground transition-colors hover:text-foreground" href={link.href}>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </nav>
    <Separator className="lg:col-span-2" />
    <p class="text-xs text-muted-foreground lg:col-span-2">
      Micronaut is a registered trademark of Object Computing, Inc. This Astro site keeps the public website, docs, guides, and Launch experience on one shared visual system.
    </p>
  </div>
</footer>
