---
import { Separator } from "@/components/ui/separator";
import { mainSiteFooterGroups } from "@/data/main-site-pages";
import { MicronautLogo } from "@/components/web/micronaut-logo";
import { withBasePath } from "@/lib/base-path";
---

<footer class="border-t bg-card">
  <div class="mx-auto grid max-w-[var(--page-max)] gap-12 px-5 py-14 sm:px-6 lg:grid-cols-[minmax(0,1fr)_2.2fr] lg:py-16 xl:px-0">
    <div>
      <a href={withBasePath("/")} class="inline-flex items-center">
        <MicronautLogo className="h-10 w-[176px]" />
      </a>
      <p class="mt-4 max-w-sm text-sm leading-7 text-muted-foreground">
        Micronaut is a modern JVM framework for building modular, testable cloud applications.
      </p>
    </div>
    <nav class="grid gap-8 sm:grid-cols-2 lg:grid-cols-5" aria-label="Main site footer">
      {mainSiteFooterGroups.map((group) => (
        <div>
          <h2 class="text-sm font-semibold text-foreground">{group.title}</h2>
          <ul class="mt-4 grid gap-2.5 leading-7">
            {group.links.map((link) => (
              <li>
                <a class="text-[0.82rem] text-muted-foreground transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50" href={withBasePath(link.href)}>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </nav>
    <Separator className="lg:col-span-2" />
    <p class="text-xs leading-6 text-muted-foreground lg:col-span-2">
      Micronaut is a registered trademark of Object Computing, Inc. This Astro site keeps the public website, docs, guides, and Launch experience on one shared visual system.
    </p>
  </div>
</footer>
