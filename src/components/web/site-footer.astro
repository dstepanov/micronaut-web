---
import { Separator } from "@/components/ui/separator";
import { IconGlyph } from "@/components/web/icon-glyph";
import { MicronautLogo } from "@/components/web/micronaut-logo";
import { withBasePath } from "@/lib/base-path";
import { getMainSiteFooterGroups } from "@/lib/main-site-content";

const footerPaths = [
  {
    label: "Learn Micronaut",
    description: "Find learning paths and training.",
    href: "/learn/",
    icon: "book-open"
  },
  {
    label: "Explore resources",
    description: "Browse support, events, and updates.",
    href: "/resources/",
    icon: "route"
  },
  {
    label: "Download Micronaut",
    description: "Use Launch, CLI, or build tools.",
    href: "/download/",
    icon: "rocket"
  }
];
const mainSiteFooterGroups = await getMainSiteFooterGroups();
---

<footer class="border-t bg-muted/35">
  <div class="mx-auto grid max-w-[var(--page-max)] gap-10 px-5 py-12 sm:px-6 lg:grid-cols-[minmax(0,1fr)_2.2fr] lg:py-14 xl:px-0">
    <div class="grid gap-3 rounded-xl border bg-card p-4 shadow-sm shadow-black/[0.02] sm:grid-cols-3 lg:col-span-2">
      {footerPaths.map((path) => (
        <a
          href={withBasePath(path.href)}
          class="group grid grid-cols-[36px_minmax(0,1fr)] gap-3 rounded-lg p-2 no-underline outline-none transition hover:bg-accent/60 focus-visible:ring-[3px] focus-visible:ring-ring/50"
        >
          <span class="grid size-9 place-items-center rounded-md bg-brand-soft text-brand transition group-hover:bg-brand group-hover:text-brand-foreground">
            <IconGlyph name={path.icon} className="size-4" />
          </span>
          <span class="min-w-0">
            <span class="block text-sm font-semibold leading-5 text-foreground">{path.label}</span>
            <span class="mt-0.5 block text-xs leading-5 text-muted-foreground">{path.description}</span>
          </span>
        </a>
      ))}
    </div>
    <div>
      <a href={withBasePath("/")} class="inline-flex items-center" aria-label="Micronaut home">
        <MicronautLogo className="h-12 w-[210px]" />
      </a>
      <p class="mt-4 max-w-sm text-sm leading-7 text-muted-foreground">
        Micronaut is a modern JVM framework for building modular, testable cloud applications.
      </p>
    </div>
    <nav class="grid gap-8 sm:grid-cols-2 lg:grid-cols-5" aria-label="Main site footer">
      {mainSiteFooterGroups.map((group) => (
        <div>
          <h2 class="text-sm font-semibold text-foreground">{group.title}</h2>
          <ul class="mt-4 grid gap-2.5 leading-7">
            {group.links.map((link) => (
              <li>
                <a
                  class="text-[0.86rem] text-muted-foreground transition-colors hover:text-foreground hover:underline focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50"
                  href={withBasePath(link.href)}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </nav>
    <Separator className="lg:col-span-2" />
    <p class="text-xs leading-6 text-muted-foreground lg:col-span-2">
      Micronaut is a registered trademark of Object Computing, Inc.
    </p>
  </div>
</footer>
