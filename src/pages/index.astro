---
import WebLayout from "@/layouts/WebLayout.astro";
import { Badge } from "@/components/ui/badge";
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle
} from "@/components/ui/card";
import { Separator } from "@/components/ui/separator";
import { ActionLink } from "@/components/web/action-link";
import { IconGlyph } from "@/components/web/icon-glyph";
import { MainCodeShowcase } from "@/components/web/main-code-showcase";
import SiteFooter from "@/components/web/site-footer.astro";
import { successStories } from "@/data/main-site-pages";
import { withBasePath } from "@/lib/base-path";

const features = [
  {
    title: "Compile-time dependency injection",
    icon: "cpu",
    copy: "Generate dependency metadata at build time and reduce runtime reflection.",
    href: "/docs/core/",
    priority: true
  },
  {
    title: "Fast startup and low memory",
    icon: "gauge",
    copy: "Designed for lean services, serverless functions, and native images.",
    href: "/docs/aot/",
    priority: true
  },
  {
    title: "Cloud-native by default",
    icon: "cloud",
    copy: "Service discovery, tracing, configuration, and cloud runtime support.",
    href: "/docs/kubernetes/",
    priority: true
  },
  {
    title: "Built-in testing support",
    icon: "test-tube-2",
    copy: "Start tests quickly with dependency injection and application context support.",
    href: "/docs/test/",
    priority: true
  },
  {
    title: "HTTP server and client",
    icon: "route",
    copy: "Create controllers and declarative clients with familiar annotations.",
    href: "/docs/core/"
  },
  {
    title: "Micronaut Data",
    icon: "database",
    copy: "Repository APIs that avoid runtime model scanning.",
    href: "/docs/data/"
  },
  {
    title: "OpenAPI Visibility",
    icon: "file-json",
    copy: "Keep service contracts discoverable and documented.",
    href: "/docs/openapi/"
  },
  {
    title: "Java, Kotlin, and Groovy",
    icon: "code",
    copy: "Use the JVM language that fits your team.",
    href: "/learn/"
  }
];

const cloudLogos = [
  { label: "Kubernetes", icon: "brand:kubernetes" },
  { label: "Google Cloud", icon: "brand:googlecloud" },
  { label: "Oracle Cloud", icon: "brand:oracle" },
  { label: "OpenTelemetry", icon: "brand:opentelemetry" },
  { label: "Apache Kafka", icon: "brand:apachekafka" },
  { label: "Redis", icon: "brand:redis" },
  { label: "MongoDB", icon: "brand:mongodb" }
];

const stories = successStories.map((story) => ({
  ...story,
  logo: story.logo ? withBasePath(story.logo) : undefined
}));

const customerLogos = [
  { name: "Samsung SmartThings", image: withBasePath("/micronaut-assets/home/samsung-smart-things.png"), className: "h-12" },
  { name: "Target", image: withBasePath("/micronaut-assets/home/target.png"), className: "h-16" },
  { name: "Minecraft", image: withBasePath("/micronaut-assets/home/minecraft.png"), className: "h-12" },
  { name: "Mojang", image: withBasePath("/micronaut-assets/home/mojang.png"), className: "h-12" },
  { name: "AgoraPulse", image: withBasePath("/micronaut-assets/home/agorapulse-logo-white-bg.png"), className: "h-8" },
  { name: "Sonar", image: withBasePath("/micronaut-assets/home/sonar-black-and-grey.svg"), className: "h-10" }
];

const graalBullets = ["Ahead-of-time friendly", "Reduced reflection reliance", "Native-image deployment path"];
const dataBullets = ["Repository APIs", "Compile-time query model", "Reduced runtime overhead"];
const cloudBullets = ["Service discovery", "Distributed tracing", "Cloud runtimes", "Messaging and data integrations"];
const codeProofs = ["Same annotations across server and client", "Compile-time metadata generation", "Fast tests with application context support"];
---

<WebLayout
  title="Micronaut Framework"
  description="A modern, JVM-based, full-stack framework for building modular, easily testable microservice and serverless applications"
  surface="main"
>
  <main>
    <section class="border-b bg-background">
      <div class="mx-auto grid max-w-[var(--page-max)] gap-12 px-5 py-[var(--hero-y)] sm:px-6 lg:grid-cols-[minmax(0,1fr)_400px] lg:items-center xl:px-0">
        <div class="max-w-[650px]">
          <Badge variant="secondary" className="mb-5 px-3 py-1.5 text-xs">Fast cloud applications on the JVM</Badge>
          <h1 class="max-w-[650px] text-[3rem] font-extrabold leading-[1.02] text-foreground md:text-[4.05rem]">
            A modern, JVM&#8209;based framework for fast cloud applications
          </h1>
          <p class="mt-5 max-w-[620px] text-[1.05rem] leading-8 text-muted-foreground md:text-[1.1rem]">
            Build modular microservices and serverless applications with compile-time dependency injection, fast startup, low memory overhead, and GraalVM Native Image support.
          </p>
          <div class="mt-6 flex flex-wrap gap-2.5">
            <Badge variant="outline" className="bg-card px-3 py-1.5 text-xs">Compile-time DI</Badge>
            <Badge variant="outline" className="bg-card px-3 py-1.5 text-xs">No runtime reflection</Badge>
            <Badge variant="outline" className="bg-card px-3 py-1.5 text-xs">GraalVM native ready</Badge>
          </div>
          <div class="mt-7 flex flex-wrap gap-3">
            <ActionLink href="/docs/" label="View documentation" size="lg" />
            <ActionLink href="/launch/" label="Launch a project" size="lg" variant="secondary" />
            <ActionLink href="/guides/" label="Browse guides" size="lg" variant="outline" />
          </div>
          <a href={withBasePath("/guides/creating-your-first-micronaut-app/")} class="mt-5 inline-flex text-sm font-medium text-primary underline-offset-4 hover:underline">
            New to Micronaut? Start with the quickstart -&gt;
          </a>
        </div>

        <Card className="overflow-hidden border-primary/25 bg-card shadow-lg shadow-primary/5">
          <CardHeader>
            <div class="grid grid-cols-[48px_minmax(0,1fr)] gap-4">
              <div class="grid size-11 place-items-center rounded-lg bg-primary/10">
                <IconGlyph name="rocket" className="size-5 text-primary" />
              </div>
              <div>
                <CardTitle className="text-[1rem] leading-6">Reimagine startup time and memory consumption</CardTitle>
                <CardDescription className="mt-1 text-[0.84rem]">Compile-time framework work keeps runtime behavior lean.</CardDescription>
              </div>
            </div>
            <div class="mt-4 flex flex-wrap gap-2">
              <Badge variant="secondary">Compile-time DI</Badge>
              <Badge variant="secondary">No runtime reflection</Badge>
            </div>
          </CardHeader>
          <CardContent className="grid gap-4">
            <div class="relative grid gap-4 rounded-lg bg-muted/70 p-5 before:absolute before:bottom-8 before:left-[33px] before:top-8 before:w-px before:bg-primary/25">
              <div class="relative grid grid-cols-[30px_minmax(0,1fr)] gap-3">
                <span class="flex size-7 items-center justify-center rounded-full bg-primary text-xs font-semibold text-primary-foreground">1</span>
                <div>
                  <p class="text-sm font-semibold text-foreground">Analyze annotations</p>
                  <p class="mt-1 text-sm leading-6 text-muted-foreground">Resolve dependency and AOP metadata at compilation.</p>
                </div>
              </div>
              <div class="relative grid grid-cols-[30px_minmax(0,1fr)] gap-3">
                <span class="flex size-7 items-center justify-center rounded-full bg-primary text-xs font-semibold text-primary-foreground">2</span>
                <div>
                  <p class="text-sm font-semibold text-foreground">Generate metadata</p>
                  <p class="mt-1 text-sm leading-6 text-muted-foreground">Precompute the model instead of discovering it at runtime.</p>
                </div>
              </div>
              <div class="relative grid grid-cols-[30px_minmax(0,1fr)] gap-3">
                <span class="flex size-7 items-center justify-center rounded-full bg-primary text-xs font-semibold text-primary-foreground">3</span>
                <div>
                  <p class="text-sm font-semibold text-foreground">Start with less runtime work</p>
                  <p class="mt-1 text-sm leading-6 text-muted-foreground">Keep startup paths lean for services and native images.</p>
                </div>
              </div>
            </div>
            <p class="border-t pt-4 text-sm leading-6 text-muted-foreground">
              Compile-time dependency injection reduces the runtime reflection work common in traditional JVM frameworks.
            </p>
          </CardContent>
        </Card>
      </div>
    </section>

    <section class="border-b bg-muted/40">
      <div class="mx-auto grid max-w-[var(--page-max)] gap-7 px-5 py-[var(--section-y)] sm:px-6 xl:px-0">
      <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
          <Badge variant="outline">Key features</Badge>
          <h2 class="mt-4 max-w-[480px] text-3xl font-bold md:text-4xl">Built around Micronaut's strongest differentiators</h2>
        </div>
        <p class="max-w-[560px] text-base leading-7 text-muted-foreground">
          Compile-time APIs, native-image readiness, integrated testing, cloud support, and productive data access work together instead of competing for attention.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        {features.map((feature) => (
          <a
            href={withBasePath(feature.href)}
            class="group rounded-xl outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50"
            aria-label={`${feature.title}: ${feature.copy}`}
          >
            <Card className={`h-full min-h-[164px] transition group-hover:-translate-y-0.5 group-hover:border-primary/50 group-hover:bg-accent/30 group-hover:shadow-md ${feature.priority ? "border-primary/25" : ""}`}>
              <CardHeader>
                <div class="mb-2 grid size-11 place-items-center rounded-md bg-primary/10 text-primary transition group-hover:bg-primary group-hover:text-primary-foreground">
                  <IconGlyph name={feature.icon} className="size-5" />
                </div>
                <CardTitle className="text-[0.98rem] leading-6">{feature.title}</CardTitle>
                <CardDescription className="text-[0.88rem]">{feature.copy}</CardDescription>
                <span class="pt-1 text-sm font-medium text-primary opacity-0 transition group-hover:opacity-100 group-focus-visible:opacity-100">
                  Learn more -&gt;
                </span>
              </CardHeader>
            </Card>
          </a>
        ))}
      </div>
      </div>
    </section>

    <section class="border-b bg-card">
      <div class="mx-auto grid max-w-[var(--page-max)] gap-10 px-5 py-[var(--section-y)] sm:px-6 lg:grid-cols-[340px_minmax(0,1fr)] xl:px-0">
        <div>
          <Badge variant="secondary">Code examples</Badge>
          <h2 class="mt-4 text-3xl font-bold md:text-4xl">Build an endpoint, client, and test with one model</h2>
          <p class="mt-4 text-base leading-7 text-muted-foreground">
            Define a controller, create a declarative HTTP client, and test both using the same compact application model.
          </p>
          <div class="mt-6 grid gap-3 text-sm leading-6 text-muted-foreground">
            {codeProofs.map((item) => (
              <div class="flex items-start gap-2">
                <IconGlyph name="check-circle" className="mt-1 size-4 shrink-0 text-primary" />
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>
        <MainCodeShowcase client:load />
      </div>
    </section>

    <section class="border-b bg-muted/40">
      <div class="mx-auto grid max-w-[var(--page-max)] gap-7 px-5 py-[var(--section-y)] sm:px-6 xl:px-0">
      <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
          <Badge variant="outline">Who uses Micronaut?</Badge>
          <h2 class="mt-4 text-3xl font-bold md:text-4xl">Production teams build with Micronaut</h2>
          <p class="mt-4 max-w-2xl text-base leading-7 text-muted-foreground">
            Micronaut is used by teams building production JVM services, cloud platforms, and data-intensive applications.
          </p>
        </div>
        <ActionLink href="/micronaut-success-stories/" label="View all success stories" variant="outline" />
      </div>

      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {stories.map((story) => (
          <Card className="h-full transition hover:-translate-y-0.5 hover:border-primary/50 hover:shadow-md">
            <CardHeader>
              <div class="mb-2 flex items-center justify-between gap-3">
                <div class="flex h-16 min-w-0 flex-1 items-center">
                  {story.logo ? (
                    <img src={story.logo} alt={`${story.organization} logo`} class:list={["max-h-full max-w-[11rem] object-contain object-left", story.logoClass]} loading="lazy" />
                  ) : (
                    <span class="text-sm font-semibold uppercase tracking-normal text-primary">{story.organization}</span>
                  )}
                </div>
                <Badge variant="secondary">{story.tag}</Badge>
              </div>
              <CardTitle className="text-xl leading-7">{story.title}</CardTitle>
              <CardDescription className="text-[0.9rem]">{story.summary}</CardDescription>
              <p class="text-sm leading-6 text-muted-foreground">{story.detail}</p>
            </CardHeader>
            <CardFooter>
              <ActionLink href={story.href} label="Read story ->" variant="ghost" className="-ml-3" />
            </CardFooter>
          </Card>
        ))}
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-6">
        {customerLogos.map((customer) => (
          <div class="flex h-24 items-center justify-center rounded-md border bg-background px-5">
            <img src={customer.image} alt={`${customer.name} logo`} class:list={["max-h-full max-w-full object-contain", customer.className]} loading="lazy" />
          </div>
        ))}
      </div>
      </div>
    </section>

    <section class="border-b bg-card">
      <div class="mx-auto grid max-w-[var(--page-max)] gap-6 px-5 py-[var(--section-y)] sm:px-6 lg:grid-cols-3 xl:px-0">
        <Card className="h-full min-h-[440px]">
          <CardHeader>
            <IconGlyph name="cloud" className="mb-3 size-7 text-primary" />
            <CardTitle>Cloud-native by default</CardTitle>
            <CardDescription>
              Built-in support for service discovery, distributed tracing, cloud configuration, and cloud runtimes.
            </CardDescription>
          </CardHeader>
          <CardContent className="grid gap-4">
            <div class="grid gap-2 text-sm leading-6 text-muted-foreground">
              {cloudBullets.map((item) => (
                <div class="flex items-center gap-2">
                  <IconGlyph name="check-circle" className="size-4 text-primary" />
                  <span>{item}</span>
                </div>
              ))}
            </div>
            <div class="grid grid-cols-2 gap-3">
              {cloudLogos.map((item) => (
                <div class="grid min-h-16 place-items-center gap-2 rounded-md bg-muted p-3 text-center transition hover:bg-accent" title={item.label}>
                  <IconGlyph name={item.icon} className="size-6" />
                  <span class="text-xs font-medium text-muted-foreground">{item.label}</span>
                </div>
              ))}
            </div>
          </CardContent>
          <CardFooter>
            <ActionLink href="/docs/" label="Explore cloud support" variant="ghost" className="-ml-3" />
          </CardFooter>
        </Card>

        <Card className="h-full min-h-[440px]">
          <CardHeader>
            <IconGlyph name="cpu" className="mb-3 size-7 text-primary" />
            <CardTitle>GraalVM startup</CardTitle>
            <CardDescription>
              Micronaut's dependency injection and AOP model avoid reflection-heavy runtime behavior, making applications a strong fit for GraalVM Native Image.
            </CardDescription>
          </CardHeader>
          <CardContent className="grid gap-4">
            <div class="grid gap-3 rounded-lg bg-muted p-4 text-sm">
              <div class="grid grid-cols-[1fr_auto_1fr_auto_1fr] items-center gap-2">
                <div class="rounded-md bg-card p-3 text-center font-medium">Compile</div>
                <div class="h-px bg-primary/35"></div>
                <div class="rounded-md bg-card p-3 text-center font-medium">Optimize</div>
                <div class="h-px bg-primary/35"></div>
                <div class="rounded-md bg-primary p-3 text-center font-medium text-primary-foreground">Native image</div>
              </div>
            </div>
            <div class="grid gap-2 text-sm leading-6 text-muted-foreground">
              {graalBullets.map((item) => (
                <div class="flex items-center gap-2">
                  <IconGlyph name="check-circle" className="size-4 text-primary" />
                  <span>{item}</span>
                </div>
              ))}
            </div>
          </CardContent>
          <CardFooter>
            <ActionLink
              href={withBasePath("/guides/micronaut-creating-first-graal-app/")}
              label="Learn about GraalVM"
              variant="ghost"
              className="-ml-3"
            />
          </CardFooter>
        </Card>

        <Card className="h-full min-h-[440px]">
          <CardHeader>
            <IconGlyph name="database" className="mb-3 size-7 text-primary" />
            <CardTitle>Works hand-in-hand with Micronaut Data</CardTitle>
            <CardDescription>
              Build data access layers with repository APIs and compile-time query generation designed for fast, predictable applications.
            </CardDescription>
          </CardHeader>
          <CardContent className="grid gap-4">
            <div class="grid gap-2 rounded-lg bg-muted p-4 text-sm">
              <div class="rounded-md border bg-card p-3 font-medium">Repository interface</div>
              <div class="flex justify-center text-primary">
                <IconGlyph name="route" className="size-5" />
              </div>
              <div class="rounded-md border bg-card p-3 font-medium">Compile-time query model</div>
              <div class="flex justify-center text-primary">
                <IconGlyph name="route" className="size-5" />
              </div>
              <div class="rounded-md border bg-card p-3 font-medium">Database access</div>
            </div>
            <div class="grid gap-2 text-sm leading-6 text-muted-foreground">
              {dataBullets.map((item) => (
                <div class="flex items-center gap-2">
                  <IconGlyph name="check-circle" className="size-4 text-primary" />
                  <span>{item}</span>
                </div>
              ))}
            </div>
          </CardContent>
          <CardFooter>
            <ActionLink href="/docs/data/" label="View Micronaut Data docs" variant="ghost" className="-ml-3" />
          </CardFooter>
        </Card>
      </div>
    </section>

    <section class="border-y bg-muted/35">
      <div class="mx-auto grid max-w-[var(--page-max)] gap-7 px-5 py-[var(--section-y-tight)] sm:px-6 lg:grid-cols-[1fr_auto] lg:items-center xl:px-0">
      <div>
        <h2 class="text-3xl font-bold md:text-4xl">Start with docs, guides, or Launch</h2>
        <p class="mt-3 max-w-2xl text-[1rem] leading-7 text-muted-foreground">
          Choose documentation, a guided tutorial, or a generated project and start building today.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <ActionLink href="/docs/" label="View documentation" />
        <ActionLink href="/launch/" label="Launch a project" variant="secondary" />
        <ActionLink href="/guides/" label="Browse guides" variant="outline" />
      </div>
      <Separator className="lg:col-span-2" />
      </div>
    </section>
  </main>
  <SiteFooter />
</WebLayout>
