---
import WebLayout from "@/layouts/WebLayout.astro";
import { Badge } from "@/components/ui/badge";
import {
  Card,
  CardAction,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle
} from "@/components/ui/card";
import { IconGlyph } from "@/components/web/icon-glyph";
import { FaqAccordion } from "@/components/web/faq-accordion";
import GeneratedDocsEnhancer from "@/components/web/generated-docs-enhancer.astro";
import MainSiteMarkdown from "@/components/web/main-site-markdown.astro";
import SiteFooter from "@/components/web/site-footer.astro";
import { withBasePath } from "@/lib/base-path";
import {
  getBlogArchiveRoutes,
  getBlogPostByRouteSlug,
  getBlogPosts,
  getBlogPostsForArchive,
  getMainSitePages,
  getSuccessStories,
  cleanExcerptText,
  renderFaqItems,
  renderMarkdownHtml
} from "@/lib/main-site-content";

export async function getStaticPaths() {
  const mainSitePages = await getMainSitePages();
  const pageSlugs = new Set(mainSitePages.map((page) => page.slug));
  const posts = await getBlogPosts();
  const archives = await getBlogArchiveRoutes();
  return [
    ...mainSitePages.map((page) => ({
      params: { slug: page.slug },
      props: { page }
    })),
    ...archives
      .filter((archive) => !pageSlugs.has(archive.slug))
      .map((archive) => ({
        params: { slug: archive.slug },
        props: { archive }
      })),
    ...posts.flatMap((post) => post.routeSlugs
      .filter((routeSlug) => !pageSlugs.has(routeSlug) && !(routeSlug.startsWith("blog/") && routeSlug.endsWith(".html")))
      .map((routeSlug) => ({
        params: { slug: routeSlug },
        props: { post }
      })))
  ];
}

const { archive, page, post } = Astro.props;
const routeSlug = page?.slug ?? archive?.slug ?? post.slug;
const relatedPost = post ?? (!archive ? await getBlogPostByRouteSlug(routeSlug) : undefined);
const entry = relatedPost?.entry ?? page?.entry;
const pageData = page?.entry.data ?? (archive ? {
  title: archive.title,
  eyebrow: archive.eyebrow,
  description: archive.description,
  intro: archive.description,
  contentSource: "blog-archive"
} : {
  title: relatedPost.entry.data.title,
  eyebrow: relatedPost.entry.data.category === "success-story" ? "Success story" : "Blog",
  description: cleanExcerptText(relatedPost.entry.data.description),
  intro: undefined,
  contentSource: relatedPost.entry.data.contentSource
});
const pageDescription = cleanExcerptText(pageData.description);
const intro = pageData.intro ? cleanExcerptText(pageData.intro) : (relatedPost ? undefined : pageDescription);
const isSuccessStoriesIndex = routeSlug === "micronaut-success-stories";
const isBlogArchiveRoute = routeSlug === "blog"
  || routeSlug.startsWith("blog/page/")
  || routeSlug.startsWith("tag/")
  || routeSlug.startsWith("category/");
const isFaqPage = routeSlug === "faq";
const isCanonicalPageContent = String(pageData.contentSource ?? "").startsWith("micronaut-public");
const archivePosts = await getBlogPostsForArchive(routeSlug);
const regularBlogPostCount = routeSlug === "blog"
  ? (await getBlogPosts()).filter((candidate) => candidate.entry.data.category !== "success-story").length
  : 0;
const blogArchivePage = archive?.page ?? (routeSlug === "blog" ? 1 : undefined);
const blogArchiveTotalPages = archive?.totalPages ?? (routeSlug === "blog" ? Math.ceil(regularBlogPostCount / 24) : undefined);
const faqItems = entry && isFaqPage ? await renderFaqItems(entry) : [];
const contentHtml = entry && !isBlogArchiveRoute && !isFaqPage ? await renderMarkdownHtml(entry) : "";
const successStories = await getSuccessStories();
const postDateFormatter = new Intl.DateTimeFormat("en", {
  day: "numeric",
  month: "short",
  year: "numeric"
});
const successStoryCards = successStories.map((story) => ({
  ...story,
  logo: story.logo ? withBasePath(story.logo) : undefined,
  initials: story.organization
    .split(/\s+/)
    .slice(0, 2)
    .map((word) => word[0])
    .join("")
    .toUpperCase()
}));
const featuredStory = successStoryCards[1];
const outcomeGroups = [
  {
    title: "Cloud and serverless",
    body: "Lambda, SnapStart, GraalVM native images, AWS delivery, and serverless cold-start pressure.",
    stories: ["Sonar", "Agorapulse", "Caribou", "Conference Scheduling Solutions"]
  },
  {
    title: "Modernization",
    body: "Monolith migration, Grails migration, obsolete tool replacement, and microservice delivery.",
    stories: ["Samsung SmartThings", "Agorapulse", "Multinational manufacturer"]
  },
  {
    title: "Platform APIs",
    body: "REST APIs, HTTP clients, OpenAPI generation, Kubernetes probes, observability, and plugin ecosystems.",
    stories: ["Kestra", "Sonar", "Caribou"]
  }
];
---

<WebLayout title={`${pageData.title} | Micronaut`} description={pageDescription} surface="main">
  {isSuccessStoriesIndex ? (
    <main class="bg-background">
      <section class="border-b bg-card">
        <div class="mx-auto grid max-w-[var(--page-max)] gap-10 px-5 py-[var(--section-y-tight)] sm:px-6 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-end xl:px-0">
          <div>
            <Badge variant="secondary">Production stories</Badge>
            <h1 class="mt-5 max-w-3xl text-4xl font-bold leading-tight text-foreground md:text-5xl">
              Micronaut success stories
            </h1>
            <p class="mt-5 max-w-3xl text-base leading-8 text-muted-foreground md:text-[1.05rem]">
              Real teams use Micronaut for serverless APIs, Grails migrations, workflow orchestration, IoT microservices, event platforms, legacy tool upgrades, and SaaS backends.
            </p>
          </div>
          {featuredStory && (
            <Card className="border-brand-border shadow-md shadow-black/[0.03]">
              <CardHeader>
                <div class="flex h-12 min-w-0 items-center">
                  {featuredStory.logo ? (
                    <img src={featuredStory.logo} alt={`${featuredStory.organization} logo`} class:list={["max-h-full max-w-[11rem] object-contain object-left", featuredStory.logoClass]} loading="lazy" />
                  ) : (
                    <span class="grid size-11 place-items-center rounded-lg bg-brand-soft text-sm font-semibold text-brand">{featuredStory.initials}</span>
                  )}
                </div>
                <CardAction className="row-span-1">
                  <Badge variant="outline">{featuredStory.tag}</Badge>
                </CardAction>
                <CardTitle className="col-span-full text-xl leading-7">{featuredStory.scenario}</CardTitle>
                <CardDescription className="col-span-full text-[0.94rem]">{featuredStory.summary}</CardDescription>
              </CardHeader>
              <CardContent>
                <div class="flex flex-wrap gap-2">
                  {featuredStory.proofs?.map((proof) => (
                    <Badge variant="secondary">{proof}</Badge>
                  ))}
                </div>
              </CardContent>
              <CardFooter>
                <a href={withBasePath(featuredStory.href)} class="text-sm font-medium text-brand underline-offset-4 hover:underline">
                  Read featured story -&gt;
                </a>
              </CardFooter>
            </Card>
          )}
        </div>
      </section>

      <section class="border-b">
        <div class="mx-auto grid max-w-[var(--page-max)] gap-6 px-5 py-[var(--section-y)] sm:px-6 xl:px-0">
          <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
            <div>
              <Badge variant="outline">Scenarios</Badge>
              <h2 class="mt-4 max-w-2xl text-3xl font-bold md:text-4xl">Different production paths, one framework model</h2>
            </div>
            <p class="max-w-xl text-base leading-7 text-muted-foreground">
              Each card highlights the real-world problem, how Micronaut fits, and what the story proves.
            </p>
          </div>

          <div class="grid gap-4 lg:grid-cols-2">
            {successStoryCards.map((story) => (
              <Card className="h-full transition hover:-translate-y-0.5 hover:border-brand/50 hover:shadow-md">
                <CardHeader>
                  <div class="flex h-12 min-w-0 items-center">
                    {story.logo ? (
                      <img src={story.logo} alt={`${story.organization} logo`} class:list={["max-h-full max-w-[10rem] object-contain object-left", story.logoClass]} loading="lazy" />
                    ) : (
                      <span class="grid size-11 place-items-center rounded-lg bg-brand-soft text-sm font-semibold text-brand">{story.initials}</span>
                    )}
                  </div>
                  <CardAction className="row-span-1">
                    <Badge variant="outline">{story.tag}</Badge>
                  </CardAction>
                  <CardTitle className="col-span-full text-xl leading-7">{story.scenario}</CardTitle>
                  <CardDescription className="col-span-full text-[0.95rem]">{story.summary}</CardDescription>
                </CardHeader>
                <CardContent className="grid gap-4">
                  <div class="grid gap-3 text-sm leading-6">
                    <div>
                      <p class="font-semibold text-foreground">Challenge</p>
                      <p class="mt-1 text-muted-foreground">{story.challenge}</p>
                    </div>
                    <div>
                      <p class="font-semibold text-foreground">Micronaut fit</p>
                      <p class="mt-1 text-muted-foreground">{story.micronautUse}</p>
                    </div>
                    <div>
                      <p class="font-semibold text-foreground">Outcome</p>
                      <p class="mt-1 text-muted-foreground">{story.outcome}</p>
                    </div>
                  </div>
                  <div class="flex flex-wrap gap-2">
                    {story.technologies.map((technology) => (
                      <Badge variant="secondary">{technology}</Badge>
                    ))}
                  </div>
                </CardContent>
                <CardFooter className="mt-auto">
                  <a href={withBasePath(story.href)} class="text-sm font-medium text-brand underline-offset-4 hover:underline">
                    Read story -&gt;
                  </a>
                </CardFooter>
              </Card>
            ))}
          </div>
        </div>
      </section>

      <section class="border-b bg-card">
        <div class="mx-auto grid max-w-[var(--page-max)] gap-6 px-5 py-[var(--section-y-tight)] sm:px-6 lg:grid-cols-3 xl:px-0">
          {outcomeGroups.map((group) => (
            <Card className="h-full">
              <CardHeader>
                <CardTitle>{group.title}</CardTitle>
                <CardDescription>{group.body}</CardDescription>
              </CardHeader>
              <CardContent>
                <ul class="grid gap-2 text-sm leading-6 text-muted-foreground">
                  {group.stories.map((story) => (
                    <li class="flex items-center gap-2">
                      <IconGlyph name="check-circle" className="size-4 text-brand" />
                      <span>{story}</span>
                    </li>
                  ))}
                </ul>
              </CardContent>
            </Card>
          ))}
        </div>
      </section>
    </main>
  ) : (
    <main class="bg-card">
      <article class:list={[
        "mx-auto px-5 py-12 sm:px-6 lg:py-16",
        isCanonicalPageContent || isBlogArchiveRoute ? "max-w-[var(--page-max)]" : "max-w-[900px]"
      ]}>
        {(!isCanonicalPageContent || isBlogArchiveRoute) && (
          <header class="border-b pb-8">
            <Badge variant="secondary">{pageData.eyebrow}</Badge>
            <h1 class="mt-5 text-3xl font-bold leading-tight text-foreground md:text-5xl">
              {pageData.title}
            </h1>
            {intro && (
              <p class="mt-5 text-base leading-8 text-muted-foreground md:text-[1.05rem]">
                {intro}
              </p>
            )}
          </header>
        )}

        {isFaqPage && faqItems.length > 0 ? (
          <section class="grid gap-8">
            <header class="max-w-3xl">
              <Badge variant="secondary">{pageData.eyebrow}</Badge>
              <h1 class="mt-5 text-3xl font-bold leading-tight text-foreground md:text-5xl">
                {pageData.title}
              </h1>
              {intro && (
                <p class="mt-5 text-base leading-8 text-muted-foreground md:text-[1.05rem]">
                  {intro}
                </p>
              )}
            </header>
            <FaqAccordion items={faqItems} client:load />
          </section>
        ) : (
          <>
            <MainSiteMarkdown html={contentHtml} />
            {contentHtml && <GeneratedDocsEnhancer />}
          </>
        )}

        {archivePosts.length > 0 && (
          <section class:list={[
            "pt-8",
            contentHtml ? "mt-10 border-t" : ""
          ]}>
            <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
              <div>
                <h2 class="text-2xl font-semibold leading-tight text-foreground">
                  {routeSlug === "blog" ? "Latest articles" : "Available articles"}
                </h2>
                <p class="mt-2 text-sm leading-6 text-muted-foreground">
                  {archivePosts.length} {archivePosts.length === 1 ? "entry" : "entries"} shown
                </p>
              </div>
              {routeSlug === "blog" && blogArchiveTotalPages && blogArchiveTotalPages > 1 && (
                <a href={withBasePath("/blog/page/2/")} class="text-sm font-medium text-brand underline-offset-4 hover:underline">
                  Browse older articles -&gt;
                </a>
              )}
            </div>
            <div class="mt-5 grid gap-4 lg:grid-cols-2">
              {archivePosts.map((post) => (
                <Card className="h-full transition hover:-translate-y-0.5 hover:border-brand/50 hover:shadow-md">
                  <CardHeader>
                    <div class="col-span-full flex flex-wrap items-center gap-2 text-xs text-muted-foreground">
                      {post.entry.data.date && (
                        <span>{postDateFormatter.format(post.entry.data.date)}</span>
                      )}
                      {post.entry.data.category && (
                        <Badge variant="outline">{post.entry.data.category}</Badge>
                      )}
                    </div>
                    <CardTitle className="col-span-full text-xl leading-7">{post.entry.data.title}</CardTitle>
                    <CardDescription className="col-span-full line-clamp-3">{cleanExcerptText(post.entry.data.description)}</CardDescription>
                  </CardHeader>
                  <CardFooter className="mt-auto">
                    <a href={withBasePath(post.href)} class="text-sm font-medium text-brand underline-offset-4 hover:underline">
                      Read article -&gt;
                    </a>
                  </CardFooter>
                </Card>
              ))}
            </div>
            {blogArchivePage && blogArchiveTotalPages && blogArchiveTotalPages > 1 && (
              <nav class="mt-6 flex flex-wrap items-center justify-between gap-3 text-sm" aria-label="Blog archive pagination">
                {blogArchivePage > 2 ? (
                  <a href={withBasePath(`/blog/page/${blogArchivePage - 1}/`)} class="font-medium text-brand underline-offset-4 hover:underline">
                    &lt;- Previous
                  </a>
                ) : blogArchivePage > 1 ? (
                  <a href={withBasePath("/blog/")} class="font-medium text-brand underline-offset-4 hover:underline">
                    &lt;- Previous
                  </a>
                ) : (
                  <span />
                )}
                <span class="text-muted-foreground">Page {blogArchivePage} of {blogArchiveTotalPages}</span>
                {blogArchivePage < blogArchiveTotalPages && (
                  <a href={withBasePath(`/blog/page/${blogArchivePage + 1}/`)} class="font-medium text-brand underline-offset-4 hover:underline">
                    Next -&gt;
                  </a>
                )}
              </nav>
            )}
          </section>
        )}
      </article>
    </main>
  )}
  <SiteFooter />
</WebLayout>
