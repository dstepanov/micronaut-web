---
import WebLayout from "@/layouts/WebLayout.astro";
import { Badge } from "@/components/ui/badge";
import {
  Card,
  CardAction,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle
} from "@/components/ui/card";
import { IconGlyph } from "@/components/web/icon-glyph";
import SiteFooter from "@/components/web/site-footer.astro";
import { mainSitePageContent, mainSitePages, successStories } from "@/data/main-site-pages";
import { withBasePath } from "@/lib/base-path";

export function getStaticPaths() {
  return mainSitePages.map((page) => ({
    params: { slug: page.slug },
    props: { page }
  }));
}

const { page } = Astro.props;
const content = mainSitePageContent[page.slug];
const intro = content?.intro ?? page.description;
const isSuccessStoriesIndex = page.slug === "micronaut-success-stories";
const successStoryCards = successStories.map((story) => ({
  ...story,
  logo: story.logo ? withBasePath(story.logo) : undefined,
  initials: story.organization
    .split(/\s+/)
    .slice(0, 2)
    .map((word) => word[0])
    .join("")
    .toUpperCase()
}));
const featuredStory = successStoryCards[1];
const outcomeGroups = [
  {
    title: "Cloud and serverless",
    body: "Lambda, SnapStart, GraalVM native images, AWS delivery, and serverless cold-start pressure.",
    stories: ["Sonar", "Agorapulse", "Caribou", "Conference Scheduling Solutions"]
  },
  {
    title: "Modernization",
    body: "Monolith migration, Grails migration, obsolete tool replacement, and microservice delivery.",
    stories: ["Samsung SmartThings", "Agorapulse", "Multinational manufacturer"]
  },
  {
    title: "Platform APIs",
    body: "REST APIs, HTTP clients, OpenAPI generation, Kubernetes probes, observability, and plugin ecosystems.",
    stories: ["Kestra", "Sonar", "Caribou"]
  }
];
---

<WebLayout title={`${page.title} | Micronaut`} description={page.description} surface="main">
  {isSuccessStoriesIndex ? (
    <main class="bg-background">
      <section class="border-b bg-card">
        <div class="mx-auto grid max-w-[var(--page-max)] gap-10 px-5 py-[var(--section-y-tight)] sm:px-6 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-end xl:px-0">
          <div>
            <Badge variant="secondary">Production stories</Badge>
            <h1 class="mt-5 max-w-3xl text-4xl font-bold leading-tight text-foreground md:text-5xl">
              Micronaut success stories
            </h1>
            <p class="mt-5 max-w-3xl text-base leading-8 text-muted-foreground md:text-[1.05rem]">
              Real teams use Micronaut for serverless APIs, Grails migrations, workflow orchestration, IoT microservices, event platforms, legacy tool upgrades, and SaaS backends.
            </p>
          </div>
          {featuredStory && (
            <Card className="border-primary/25 shadow-md shadow-black/[0.03]">
              <CardHeader>
                <div class="flex h-12 min-w-0 items-center">
                  {featuredStory.logo ? (
                    <img src={featuredStory.logo} alt={`${featuredStory.organization} logo`} class:list={["max-h-full max-w-[11rem] object-contain object-left", featuredStory.logoClass]} loading="lazy" />
                  ) : (
                    <span class="grid size-11 place-items-center rounded-lg bg-primary/10 text-sm font-semibold text-primary">{featuredStory.initials}</span>
                  )}
                </div>
                <CardAction className="row-span-1">
                  <Badge variant="outline">{featuredStory.tag}</Badge>
                </CardAction>
                <CardTitle className="col-span-full text-xl leading-7">{featuredStory.scenario}</CardTitle>
                <CardDescription className="col-span-full text-[0.94rem]">{featuredStory.summary}</CardDescription>
              </CardHeader>
              <CardContent>
                <div class="flex flex-wrap gap-2">
                  {featuredStory.proofs?.map((proof) => (
                    <Badge variant="secondary">{proof}</Badge>
                  ))}
                </div>
              </CardContent>
              <CardFooter>
                <a href={withBasePath(featuredStory.href)} class="text-sm font-medium text-primary underline-offset-4 hover:underline">
                  Read featured story -&gt;
                </a>
              </CardFooter>
            </Card>
          )}
        </div>
      </section>

      <section class="border-b">
        <div class="mx-auto grid max-w-[var(--page-max)] gap-6 px-5 py-[var(--section-y)] sm:px-6 xl:px-0">
          <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
            <div>
              <Badge variant="outline">Scenarios</Badge>
              <h2 class="mt-4 max-w-2xl text-3xl font-bold md:text-4xl">Different production paths, one framework model</h2>
            </div>
            <p class="max-w-xl text-base leading-7 text-muted-foreground">
              Each card highlights the real-world problem, how Micronaut fits, and what the story proves.
            </p>
          </div>

          <div class="grid gap-4 lg:grid-cols-2">
            {successStoryCards.map((story) => (
              <Card className="h-full transition hover:-translate-y-0.5 hover:border-primary/50 hover:shadow-md">
                <CardHeader>
                  <div class="flex h-12 min-w-0 items-center">
                    {story.logo ? (
                      <img src={story.logo} alt={`${story.organization} logo`} class:list={["max-h-full max-w-[10rem] object-contain object-left", story.logoClass]} loading="lazy" />
                    ) : (
                      <span class="grid size-11 place-items-center rounded-lg bg-primary/10 text-sm font-semibold text-primary">{story.initials}</span>
                    )}
                  </div>
                  <CardAction className="row-span-1">
                    <Badge variant="outline">{story.tag}</Badge>
                  </CardAction>
                  <CardTitle className="col-span-full text-xl leading-7">{story.scenario}</CardTitle>
                  <CardDescription className="col-span-full text-[0.95rem]">{story.summary}</CardDescription>
                </CardHeader>
                <CardContent className="grid gap-4">
                  <div class="grid gap-3 text-sm leading-6">
                    <div>
                      <p class="font-semibold text-foreground">Challenge</p>
                      <p class="mt-1 text-muted-foreground">{story.challenge}</p>
                    </div>
                    <div>
                      <p class="font-semibold text-foreground">Micronaut fit</p>
                      <p class="mt-1 text-muted-foreground">{story.micronautUse}</p>
                    </div>
                    <div>
                      <p class="font-semibold text-foreground">Outcome</p>
                      <p class="mt-1 text-muted-foreground">{story.outcome}</p>
                    </div>
                  </div>
                  <div class="flex flex-wrap gap-2">
                    {story.technologies.map((technology) => (
                      <Badge variant="secondary">{technology}</Badge>
                    ))}
                  </div>
                </CardContent>
                <CardFooter className="mt-auto">
                  <a href={withBasePath(story.href)} class="text-sm font-medium text-primary underline-offset-4 hover:underline">
                    Read story -&gt;
                  </a>
                </CardFooter>
              </Card>
            ))}
          </div>
        </div>
      </section>

      <section class="border-b bg-card">
        <div class="mx-auto grid max-w-[var(--page-max)] gap-6 px-5 py-[var(--section-y-tight)] sm:px-6 lg:grid-cols-3 xl:px-0">
          {outcomeGroups.map((group) => (
            <Card className="h-full">
              <CardHeader>
                <CardTitle>{group.title}</CardTitle>
                <CardDescription>{group.body}</CardDescription>
              </CardHeader>
              <CardContent>
                <ul class="grid gap-2 text-sm leading-6 text-muted-foreground">
                  {group.stories.map((story) => (
                    <li class="flex items-center gap-2">
                      <IconGlyph name="check-circle" className="size-4 text-primary" />
                      <span>{story}</span>
                    </li>
                  ))}
                </ul>
              </CardContent>
            </Card>
          ))}
        </div>
      </section>
    </main>
  ) : (
    <main class="bg-card">
      <article class="mx-auto max-w-[900px] px-5 py-12 sm:px-6 lg:py-16">
        <header class="border-b pb-8">
          <Badge variant="secondary">{page.eyebrow}</Badge>
          <h1 class="mt-5 text-3xl font-bold leading-tight text-foreground md:text-5xl">
            {page.title}
          </h1>
          {intro && (
            <p class="mt-5 text-base leading-8 text-muted-foreground md:text-[1.05rem]">
              {intro}
            </p>
          )}
        </header>

        <div class="divide-y">
          {(content?.blocks ?? []).map((block) => (
            <section class="py-8">
              <h2 class="text-2xl font-semibold leading-tight text-foreground">{block.title}</h2>
              {block.body && <p class="mt-3 text-base leading-8 text-muted-foreground">{block.body}</p>}
              {block.items && (
                <ul class="mt-5 grid gap-3 text-base leading-7 text-muted-foreground">
                  {block.items.map((item) => (
                    <li class="grid grid-cols-[20px_minmax(0,1fr)] gap-3">
                      <IconGlyph name="check-circle" className="mt-1 size-4 text-primary" />
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              )}
              {block.code && (
                <pre class="mt-5 overflow-x-auto rounded-lg border bg-[#151a20] p-4 text-[0.82rem] leading-6 text-[#f6f8f9]"><code>{block.code}</code></pre>
              )}
              {block.links && block.links.length > 0 && (
                <div class="mt-5 flex flex-wrap gap-x-5 gap-y-2">
                  {block.links.map((link) => (
                    <a
                      href={link.external ? link.href : withBasePath(link.href)}
                      class="text-sm font-medium text-primary underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50"
                      target={link.external ? "_blank" : undefined}
                      rel={link.external ? "noreferrer" : undefined}
                    >
                      {link.label} -&gt;
                    </a>
                  ))}
                </div>
              )}
            </section>
          ))}
        </div>
      </article>
    </main>
  )}
  <SiteFooter />
</WebLayout>
