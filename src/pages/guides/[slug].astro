---
import WebLayout from "@/layouts/WebLayout.astro";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { Separator } from "@/components/ui/separator";
import GeneratedDocsStaticEnhancer from "@/components/web/generated-docs-static-enhancer.astro";
import LatestGuidesCatalog from "@/components/web/latest-guides-catalog.astro";
import {
  allGeneratedGuideTags,
  guideOptionPath,
  guideOverviewPath,
  guideTagPath,
  readGeneratedGuideFragment,
  readGeneratedGuidesManifest,
  tagSlug,
  type GeneratedGuide,
  type GeneratedGuideOption
} from "@/lib/generated-guides";
import { withBasePath } from "@/lib/base-path";
import { shouldBuildGuidesRoutes } from "@/lib/surface-routes";

const guidesRoot = "/guides";

type TagProps = {
  kind: "tag";
  tag: string;
  guides: GeneratedGuide[];
};

type OverviewProps = {
  kind: "overview";
  guide: GeneratedGuide;
};

type VariantProps = {
  kind: "variant";
  guide: GeneratedGuide;
  option: GeneratedGuideOption;
};

export async function getStaticPaths() {
  if (!shouldBuildGuidesRoutes()) {
    return [];
  }
  const manifest = await readGeneratedGuidesManifest();
  const paths: Array<{ params: { slug: string }; props: TagProps | OverviewProps | VariantProps }> = [];
  const pages = new Set<string>();
  const addPath = (slug: string, props: TagProps | OverviewProps | VariantProps) => {
    if (pages.has(slug)) {
      return;
    }
    pages.add(slug);
    paths.push({ params: { slug }, props });
  };

  for (const tag of allGeneratedGuideTags(manifest.guides)) {
    addPath(`tag-${tagSlug(tag)}`, { kind: "tag", tag, guides: manifest.guides });
  }
  for (const guide of manifest.guides) {
    addPath(guide.slug, { kind: "overview", guide });
    for (const option of guide.options) {
      addPath(option.file.replace(/\.html$/, ""), { kind: "variant", guide, option });
    }
  }

  return paths;
}

const props = Astro.props as TagProps | OverviewProps | VariantProps;

let fragmentHtml: string | undefined;
let sections: Array<{ id: string; label: string; depth: number }> = [];
let pageIndexSections: Array<{ id: string; label: string; depth: number; rootId: string; level: number }> = [];
let guideSectionLinks: Array<{ id: string; label: string; depth: number; rootId: string; level: number }> = [];
if (props.kind === "variant") {
  fragmentHtml = await readGeneratedGuideFragment(props.option);
  sections = fragmentHtml ? extractSections(fragmentHtml) : [];
  pageIndexSections = buildGuidePageIndexSections(sections);
  guideSectionLinks = pageIndexSections.filter((section) => section.level === 0).slice(0, 30);
}

function extractSections(html: string) {
  const found: Array<{ id: string; label: string; depth: number }> = [];
  const pattern = /<h([2-6]) id="([^"]+)"[^>]*>([\s\S]*?)<\/h\1>/g;
  for (const match of html.matchAll(pattern)) {
    const label = match[3]
      .replace(/<[^>]+>/g, "")
      .replace(/&amp;/g, "&")
      .replace(/&lt;/g, "<")
      .replace(/&gt;/g, ">")
      .replace(/&quot;/g, "\"")
      .replace(/&#39;/g, "'")
      .replace(/\s+/g, " ")
      .trim();
    if (label) {
      found.push({ id: match[2], label, depth: Number(match[1]) });
    }
    if (found.length >= 200) {
      break;
    }
  }
  return found;
}

function buildGuidePageIndexSections(sections: Array<{ id: string; label: string; depth: number }>) {
  let currentRoot: { id: string; label: string; depth: number } | undefined;
  return sections.map((section) => {
    if (!currentRoot || section.depth <= 2) {
      currentRoot = section;
    }
    return {
      ...section,
      rootId: currentRoot.id,
      level: Math.min(3, Math.max(0, section.depth - currentRoot.depth))
    };
  });
}

function variantAnchor(option: GeneratedGuideOption) {
  return `variant-${option.id.replace(/[^a-zA-Z0-9_-]+/g, "-")}`;
}
---

{props.kind === "tag" && (
  <WebLayout title={`Micronaut Guides: ${props.tag}`} surface="guides">
    <LatestGuidesCatalog guides={props.guides} activeTag={props.tag} root={guidesRoot} />
  </WebLayout>
)}

{props.kind === "overview" && (
  <WebLayout title={`${props.guide.title} | Micronaut Guides`} surface="guides">
    <main class="mx-auto max-w-[1180px] px-4 py-8 md:px-6">
      <article class="min-w-0">
        <header class="mb-8">
          <Badge variant="secondary">{props.guide.categories[0] || "Guide"}</Badge>
          <h1 class="mt-5 text-4xl font-bold tracking-tight md:text-5xl">{props.guide.title}</h1>
          <p class="mt-4 max-w-3xl text-lg leading-8 text-muted-foreground">{props.guide.intro}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {props.guide.tags.slice(0, 10).map((tag) => (
              <a href={withBasePath(guideTagPath(tag, guidesRoot))} class="no-underline">
                <Badge variant="outline">{tag}</Badge>
              </a>
            ))}
          </div>
        </header>

        <Card id="variants">
          <CardHeader>
            <CardTitle>Read This Guide</CardTitle>
            <CardDescription>Choose the language and build tool variant for the tutorial.</CardDescription>
          </CardHeader>
          <CardContent>
            <div class="overflow-hidden rounded-lg border">
              <table class="w-full text-left text-sm">
                <thead class="bg-muted text-xs text-muted-foreground">
                  <tr>
                    <th class="px-4 py-3 font-medium">Language</th>
                    <th class="px-4 py-3 font-medium">Build</th>
                    <th class="px-4 py-3 font-medium">Read</th>
                  </tr>
                </thead>
                <tbody>
                  {props.guide.options.map((option) => (
                    <tr id={variantAnchor(option)} class="scroll-mt-24 border-t">
                      <td class="px-4 py-3">{option.languageLabel}</td>
                      <td class="px-4 py-3">{option.buildToolLabel}</td>
                      <td class="px-4 py-3">
                        <Button asChild variant="ghost" size="sm">
                          <a href={withBasePath(guideOptionPath(option, guidesRoot))} aria-label={`Read ${props.guide.title} for ${option.label}`}>Read</a>
                        </Button>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </CardContent>
        </Card>
      </article>
    </main>
  </WebLayout>
)}

{props.kind === "variant" && (
  <WebLayout title={`${props.guide.title} | ${props.option.label}`} surface="guides">
    <main class:list={[
      "mx-auto grid max-w-[1480px] gap-8 px-4 py-8 md:px-6",
      pageIndexSections.length > 0 ? "lg:grid-cols-[220px_minmax(0,1fr)_250px]" : "lg:grid-cols-[220px_minmax(0,1fr)]"
    ]}>
      <aside class="hidden min-w-0 lg:block" aria-label="On this guide">
        <div class="sticky top-[calc(var(--topbar-height)+24px)] grid max-h-[calc(100vh-var(--topbar-height)-48px)] gap-1.5 overflow-y-auto pb-7 pr-2 text-[0.82rem] [scrollbar-width:thin]">
          <h2 class="m-0 font-medium">On this guide</h2>
          <Separator className="opacity-70" />
          {guideSectionLinks.map((section) => (
            <a
              href={`#${section.id}`}
              class="rounded-md px-2 py-1.5 leading-5 text-muted-foreground no-underline hover:bg-accent hover:text-accent-foreground focus-visible:bg-accent focus-visible:text-accent-foreground [&.active]:bg-accent [&.active]:font-medium [&.active]:text-foreground"
              data-guide-section-link
              data-section-id={section.id}
            >
              {section.label}
            </a>
          ))}
          {guideSectionLinks.length > 0 && <Separator className="opacity-70" />}
          <h3 class="m-0 font-medium">Different variants</h3>
          {props.guide.options.map((option) => (
            <a
              href={withBasePath(guideOptionPath(option, guidesRoot))}
              aria-current={option.file === props.option.file ? "page" : undefined}
              class:list={[
                "rounded-md px-2 py-1.5 leading-5 text-muted-foreground no-underline hover:bg-accent hover:text-accent-foreground",
                option.file === props.option.file && "bg-accent font-medium text-foreground"
              ]}
            >
              {option.label}
            </a>
          ))}
        </div>
      </aside>
      <article class="min-w-0">
        <header class="mb-8">
          <Badge variant="secondary">{props.option.label}</Badge>
          <h1 class="mt-5 text-4xl font-bold tracking-tight md:text-5xl">{props.guide.title}</h1>
          <p class="mt-4 max-w-3xl text-lg leading-8 text-muted-foreground">{props.guide.intro}</p>
          <div class="mt-5 flex flex-wrap gap-2 text-sm text-muted-foreground">
            <span>{props.guide.authors.join(", ")}</span>
            <span aria-hidden="true">/</span>
            <span>{props.guide.estimatedMinutes} min</span>
            <span aria-hidden="true">/</span>
            <a href={withBasePath(guideOverviewPath(props.guide, guidesRoot))} class="text-brand no-underline hover:underline">All variants</a>
          </div>
        </header>

        <details class="mb-6 rounded-lg border bg-card p-3 lg:hidden" data-guide-mobile-guide-index>
          <summary class="cursor-pointer text-sm font-medium">On this guide</summary>
          <nav class="mt-3 grid gap-1 text-[0.86rem]" aria-label="On this guide">
            {guideSectionLinks.map((section) => (
              <a
                href={`#${section.id}`}
                class="rounded-md px-2 py-1.5 leading-5 text-muted-foreground no-underline hover:bg-accent hover:text-accent-foreground focus-visible:bg-accent focus-visible:text-accent-foreground [&.active]:bg-accent [&.active]:font-medium [&.active]:text-foreground"
                data-guide-section-link
                data-section-id={section.id}
              >
                {section.label}
              </a>
            ))}
            {guideSectionLinks.length > 0 && <Separator className="my-1 opacity-70" />}
            <h3 class="m-0 text-sm font-medium">Different variants</h3>
            {props.guide.options.map((option) => (
              <a
                href={withBasePath(guideOptionPath(option, guidesRoot))}
                aria-current={option.file === props.option.file ? "page" : undefined}
                class:list={[
                  "rounded-md px-2 py-1.5 leading-5 text-muted-foreground no-underline hover:bg-accent hover:text-accent-foreground",
                  option.file === props.option.file && "bg-accent font-medium text-foreground"
                ]}
              >
                {option.label}
              </a>
            ))}
          </nav>
        </details>

        {pageIndexSections.length > 0 && (
          <details class="mb-6 rounded-lg border bg-card p-3 lg:hidden" data-guide-mobile-index>
            <summary class="cursor-pointer text-sm font-medium">In this section</summary>
            <nav class="mt-3 grid gap-px border-l border-border pl-2.5" aria-label="Current guide sections">
              {pageIndexSections.map((section) => (
                <a
                  href={`#${section.id}`}
                  class:list={[
                    "relative block min-w-0 rounded-md py-1 pr-2 text-[0.82rem] leading-[1.4] break-words text-muted-foreground no-underline hover:bg-accent hover:text-accent-foreground focus-visible:bg-accent focus-visible:text-accent-foreground",
                    section.level === 0 && "pl-2",
                    section.level === 1 && "pl-3.5",
                    section.level === 2 && "pl-5",
                    section.level >= 3 && "pl-[1.625rem]"
                  ]}
                >
                  {section.label}
                </a>
              ))}
            </nav>
          </details>
        )}

        {fragmentHtml ? (
          <>
            <div class="generated-docs-content generated-guides-content" data-generated-docs set:html={fragmentHtml} />
            <GeneratedDocsStaticEnhancer />
          </>
        ) : (
          <Card>
            <CardHeader>
              <CardTitle>Guide content unavailable</CardTitle>
              <CardDescription>This variant was listed but no generated fragment exists for the current build.</CardDescription>
            </CardHeader>
          </Card>
        )}
      </article>
      {pageIndexSections.length > 0 && (
        <aside class="hidden min-w-0 lg:block" aria-label="In this section" data-guide-page-index>
          <div
            class="sticky top-[calc(var(--topbar-height)+24px)] max-h-[calc(100vh-var(--topbar-height)-48px)] overflow-y-auto pb-7 pr-6 font-[var(--shell-font)] [scrollbar-width:thin]"
            data-guide-page-index-inner
          >
            <div class="mb-2 flex items-center justify-between gap-2 text-[0.83rem] font-semibold leading-[1.4] text-foreground">
              <span>In this section</span>
              <a
                class="inline-grid size-6 flex-none place-items-center rounded-md text-muted-foreground no-underline hover:bg-accent hover:text-accent-foreground focus-visible:bg-accent focus-visible:text-accent-foreground"
                href={`#${pageIndexSections[0].rootId}`}
                title="Back to top"
                aria-label="Back to top"
                data-guide-page-index-top
              >
                <svg
                  class="size-3.5"
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  focusable="false"
                >
                  <path d="m5 12 7-7 7 7"></path>
                  <path d="M12 19V5"></path>
                </svg>
              </a>
            </div>
            <nav class="grid gap-px border-l border-border pl-2.5" aria-label="Current guide sections" data-guide-page-index-nav>
              {pageIndexSections.map((section) => (
                <a
                  href={`#${section.id}`}
                  class:list={[
                    "relative block min-w-0 rounded-md py-1 pr-2 text-[0.78rem] leading-[1.4] break-words text-muted-foreground no-underline hover:bg-accent hover:text-accent-foreground focus-visible:bg-accent focus-visible:text-accent-foreground [&.active]:font-medium [&.active]:text-foreground [&.active]:before:absolute [&.active]:before:bottom-[7px] [&.active]:before:left-[-11px] [&.active]:before:top-[7px] [&.active]:before:w-0.5 [&.active]:before:rounded-full [&.active]:before:bg-brand [&.active]:before:content-['']",
                    section.level === 0 && "pl-2",
                    section.level === 1 && "pl-3.5",
                    section.level === 2 && "pl-5",
                    section.level >= 3 && "pl-[1.625rem]"
                  ]}
                  data-guide-page-index-link
                  data-root-id={section.rootId}
                  data-section-id={section.id}
                >
                  {section.label}
                </a>
              ))}
            </nav>
          </div>
        </aside>
      )}
    </main>
    <script is:inline>
      (() => {
        const pageIndex = document.querySelector("[data-guide-page-index]");
        const pageIndexNav = pageIndex?.querySelector("[data-guide-page-index-nav]");
        const pageIndexTop = pageIndex?.querySelector("[data-guide-page-index-top]");
        if (!pageIndex || !pageIndexNav) {
          return;
        }

        const links = Array.from(pageIndexNav.querySelectorAll("[data-guide-page-index-link]"));
        const linksById = new Map(links.map((link) => [link.dataset.sectionId, link]));
        const guideSectionLinks = Array.from(document.querySelectorAll("[data-guide-section-link]"));
        const guideSectionLinksById = guideSectionLinks.reduce((byId, link) => {
          const sectionId = link.dataset.sectionId || "";
          const sectionLinks = byId.get(sectionId) || [];
          sectionLinks.push(link);
          byId.set(sectionId, sectionLinks);
          return byId;
        }, new Map());
        const headings = links
          .map((link) => document.getElementById(link.dataset.sectionId || ""))
          .filter(Boolean);
        let activeRootId = "";
        let activeLink;
        let activeGuideSectionId = "";
        let activeGuideSectionLinks = [];
        let updateFrame = 0;

        const scrollOffset = () => {
          const scrollPaddingTop = Number.parseFloat(getComputedStyle(document.documentElement).scrollPaddingTop);
          const fixedOffset = (Number.isFinite(scrollPaddingTop) ? scrollPaddingTop : 80) + 16;
          return Math.max(fixedOffset, window.innerHeight * 0.25);
        };

        const activeHeadingFromScroll = () => {
          if (!headings.length) {
            return undefined;
          }
          const offset = scrollOffset();
          let activeHeading = headings[0];
          for (const heading of headings) {
            if (heading.getBoundingClientRect().top <= offset) {
              activeHeading = heading;
            } else {
              break;
            }
          }
          return activeHeading;
        };

        const scrollActiveLinkIntoView = (link) => {
          const container = link?.closest("[data-guide-page-index-inner]");
          if (!container || container.scrollHeight <= container.clientHeight) {
            return;
          }
          const containerRect = container.getBoundingClientRect();
          const linkRect = link.getBoundingClientRect();
          const margin = 20;
          if (linkRect.top < containerRect.top + margin) {
            container.scrollTop -= containerRect.top + margin - linkRect.top;
          } else if (linkRect.bottom > containerRect.bottom - margin) {
            container.scrollTop += linkRect.bottom - containerRect.bottom + margin;
          }
        };

        const setActiveSection = (sectionId) => {
          const nextLink = linksById.get(sectionId) || links[0];
          const nextRootId = nextLink?.dataset.rootId || "";
          if (nextRootId && nextRootId !== activeRootId) {
            activeRootId = nextRootId;
            const rootLink = linksById.get(activeRootId);
            if (pageIndexTop) {
              const rootLabel = rootLink?.textContent?.trim() || "section";
              pageIndexTop.href = `#${activeRootId}`;
              pageIndexTop.setAttribute("aria-label", `Back to ${rootLabel}`);
              pageIndexTop.setAttribute("title", `Back to ${rootLabel}`);
            }
            for (const link of links) {
              link.hidden = link.dataset.rootId !== activeRootId;
            }
          }

          if (activeLink && activeLink !== nextLink) {
            activeLink.classList.remove("active");
            activeLink.removeAttribute("aria-current");
          }
          if (nextLink) {
            nextLink.classList.add("active");
            nextLink.setAttribute("aria-current", "location");
            activeLink = nextLink;
            scrollActiveLinkIntoView(nextLink);
          }

          if (nextRootId && nextRootId !== activeGuideSectionId) {
            activeGuideSectionId = nextRootId;
            for (const link of activeGuideSectionLinks) {
              link.classList.remove("active");
              link.removeAttribute("aria-current");
            }
            activeGuideSectionLinks = guideSectionLinksById.get(nextRootId) || [];
            for (const link of activeGuideSectionLinks) {
              link.classList.add("active");
              link.setAttribute("aria-current", "location");
            }
          }
        };

        const setActiveSectionFromHash = () => {
          if (!window.location.hash) {
            return false;
          }
          let sectionId = "";
          try {
            sectionId = decodeURIComponent(window.location.hash.slice(1));
          } catch {
            sectionId = window.location.hash.slice(1);
          }
          if (!linksById.has(sectionId)) {
            return false;
          }
          setActiveSection(sectionId);
          return true;
        };

        const updateActiveSection = () => {
          updateFrame = 0;
          const activeHeading = activeHeadingFromScroll();
          if (activeHeading) {
            setActiveSection(activeHeading.id);
          }
        };

        const queueActiveSectionUpdate = () => {
          if (updateFrame) {
            return;
          }
          updateFrame = window.requestAnimationFrame(updateActiveSection);
        };

        window.addEventListener("scroll", queueActiveSectionUpdate, { passive: true });
        window.addEventListener("resize", queueActiveSectionUpdate);
        const queueHashSectionUpdate = () => {
          window.setTimeout(() => {
            if (!setActiveSectionFromHash()) {
              queueActiveSectionUpdate();
            }
          }, 0);
          window.setTimeout(() => {
            if (!setActiveSectionFromHash()) {
              queueActiveSectionUpdate();
            }
          }, 150);
        };

        window.addEventListener("hashchange", queueHashSectionUpdate);
        if (!setActiveSectionFromHash()) {
          updateActiveSection();
        }
        queueHashSectionUpdate();
      })();
    </script>
    <style is:global>
      .generated-guides-content {
        min-width: 0;
        color: var(--foreground);
        font-size: 1rem;
        line-height: 1.6;
        overflow-wrap: break-word;
      }

      .generated-guides-content > style {
        display: none;
      }

      .generated-guides-content :where(.sect1, .sect2, .sect3, .sect4, .sect5) {
        min-width: 0;
        margin-top: 1.55rem;
      }

      .generated-guides-content :where(h2, h3, h4, h5, h6) {
        margin: 0 0 0.9rem;
        scroll-margin-top: 5rem;
        font-weight: 700;
        letter-spacing: 0;
      }

      .generated-guides-content h2 {
        font-size: clamp(1.65rem, 2.2vw, 2rem);
        line-height: 1.2;
      }

      .generated-guides-content h3 {
        font-size: 1.35rem;
        line-height: 1.3;
      }

      .generated-guides-content h4 {
        font-size: 1.15rem;
        line-height: 1.35;
      }

      .generated-guides-content .paragraph p {
        margin: 0 0 1.25rem;
      }

      .generated-guides-content :where(.ulist, .olist) {
        margin: 0 0 1.25rem;
      }

      .generated-guides-content .ulist ul {
        margin: 0;
        padding-left: 1.45rem;
        list-style: disc;
      }

      .generated-guides-content .olist ol {
        margin: 0;
        padding-left: 1.45rem;
        list-style: decimal;
      }

      .generated-guides-content li + li {
        margin-top: 0.75rem;
      }

      .generated-guides-content a {
        color: var(--brand);
        text-decoration: none;
      }

      .generated-guides-content a:hover {
        text-decoration: underline;
      }

      .generated-guides-content :not(pre) > code {
        border-radius: 0.25rem;
        background: var(--muted);
        padding: 0.05rem 0.25rem;
        color: var(--foreground);
        font-size: 0.9em;
      }

      .generated-guides-content :where(.listingblock, .literalblock, .exampleblock, .sidebarblock, .openblock, .admonitionblock, .quoteblock) {
        min-width: 0;
        margin: 1.25rem 0;
      }

      .generated-guides-content .admonitionblock {
        overflow: hidden;
        border: 1px solid var(--border);
        border-radius: 0.5rem;
        background: var(--muted);
      }

      .generated-guides-content .admonitionblock table {
        width: 100%;
        border-collapse: collapse;
      }

      .generated-guides-content .admonitionblock td.icon {
        width: 4.25rem;
        padding: 1rem 0.75rem;
        color: var(--muted-foreground);
        font-size: 0.72rem;
        font-weight: 700;
        text-align: center;
        text-transform: uppercase;
        vertical-align: top;
      }

      .generated-guides-content .admonitionblock td.content {
        padding: 1rem 1rem 1rem 0;
        vertical-align: top;
      }

      .generated-guides-content table.tableblock {
        width: 100%;
        margin: 1.25rem 0;
        border-collapse: collapse;
        font-size: 0.92rem;
        line-height: 1.45;
      }

      .generated-guides-content table.tableblock :where(th, td) {
        border: 1px solid var(--border);
        padding: 0.65rem 0.75rem;
        vertical-align: top;
      }

      .generated-guides-content table.tableblock th {
        background: var(--muted);
        font-weight: 700;
      }

      .generated-guides-content img {
        max-width: 100%;
        height: auto;
      }

      .generated-guides-content .colist {
        margin: -0.4rem 0 1.25rem;
        color: var(--muted-foreground);
        font-size: 0.9rem;
      }
    </style>
  </WebLayout>
)}
