---
import WebLayout from "@/layouts/WebLayout.astro";
import { Badge } from "@/components/ui/badge";
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle
} from "@/components/ui/card";
import { Separator } from "@/components/ui/separator";
import { DocsShell } from "@/components/web/docs-shell";
import { IconGlyph } from "@/components/web/icon-glyph";
import { ProjectReferenceLinks } from "@/components/web/project-reference-links";
import { micronautProtocol, projectBySlug } from "@/lib/protocol";

export function getStaticPaths() {
  return micronautProtocol.docs.projects.map((project) => ({
    params: { slug: project.slug }
  }));
}

const project = projectBySlug(Astro.params.slug!);
if (!project) {
  return Astro.redirect("/docs/");
}
---

<WebLayout title={`${project.displayName} Docs`} surface="docs" hideHeader>
  <DocsShell activeSlug={project.slug} client:load>
    <article class="mx-auto grid w-full max-w-[1180px] grid-cols-1 gap-8 px-4 py-8 md:px-6 xl:grid-cols-[minmax(0,1fr)_240px]">
      <div class="min-w-0">
        <header class="mb-8">
          <div class="mb-5 flex items-center gap-3">
            <span class="flex size-12 items-center justify-center rounded-xl bg-secondary">
              <IconGlyph name={project.icon} className="size-6" />
            </span>
            <Badge variant="secondary">{project.primaryCategory}</Badge>
          </div>
          <h1 class="text-4xl font-bold tracking-tight md:text-5xl">{project.displayName}</h1>
          <p class="mt-4 max-w-3xl text-lg leading-8 text-muted-foreground">{project.longDescription}</p>
          <ProjectReferenceLinks references={project.references} />
        </header>
        <div class="grid gap-8 text-base leading-7">
          {project.sections.map((section) => (
            <section id={section.id} class="scroll-mt-24">
              <h2 class="text-2xl font-semibold tracking-tight">{section.number}. {section.title}</h2>
              <p class="mt-3 max-w-3xl text-muted-foreground">{section.summary}</p>
              <Card className="mt-4">
                <CardHeader>
                  <CardTitle className="text-base">{section.title}</CardTitle>
                  <CardDescription>{project.displayName} protocol-backed content placeholder.</CardDescription>
                </CardHeader>
                <CardContent>
                  <p>
                    This page is rendered from the shared JSON protocol. The same contract can later point to generated
                    static guide fragments, API references, configuration pages, and search entries.
                  </p>
                  <div class="mt-4 overflow-hidden rounded-lg border bg-muted/50">
                    <pre class="overflow-x-auto p-4 text-sm leading-7"><code>{`micronaut.project=${project.slug}
micronaut.module=${project.module}
micronaut.category=${project.primaryCategory}`}</code></pre>
                  </div>
                </CardContent>
              </Card>
            </section>
          ))}
        </div>
      </div>
      <aside class="hidden xl:block">
        <div class="sticky top-24 grid gap-2 text-sm">
          <h2 class="font-medium">In this section</h2>
          <Separator className="opacity-70" />
          {project.sections.map((section) => (
            <a href={`#${section.id}`} class="rounded-md px-2 py-1.5 text-muted-foreground no-underline hover:bg-accent hover:text-accent-foreground">
              {section.number}. {section.title}
            </a>
          ))}
        </div>
      </aside>
    </article>
  </DocsShell>
</WebLayout>
