---
import { readFile } from "node:fs/promises";
import { join } from "node:path";

import WebLayout from "@/layouts/WebLayout.astro";
import { Badge } from "@/components/ui/badge";
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle
} from "@/components/ui/card";
import { Separator } from "@/components/ui/separator";
import DocsShell from "@/components/web/docs-shell.astro";
import GeneratedDocsStaticEnhancer from "@/components/web/generated-docs-static-enhancer.astro";
import { IconBadge } from "@/components/web/icon-badge";
import { ProjectReferenceLinks } from "@/components/web/project-reference-links";
import { canonicalSurfaceUrl, withBasePath } from "@/lib/base-path";
import {
  docsCatalogProject,
  loadDocsProjectCatalog,
} from "@/lib/docs-project-catalog";
import {
  enhanceGeneratedContentHtml,
  generatedHtmlLabel,
} from "@/lib/generated-docs-html";
import { shouldBuildDocsRoutes } from "@/lib/surface-routes";
import "@/styles/generated-docs-content.css";
import generatedDocsHashAlignerUrl from "@/scripts/generated-docs-hash-aligner.ts?url";

export async function getStaticPaths() {
  if (!shouldBuildDocsRoutes()) {
    return [];
  }
  const docsProjectCatalog = await loadDocsProjectCatalog();
  return docsProjectCatalog.projects.map((project) => ({
    params: { slug: project.slug }
  }));
}

const docsProjectCatalog = await loadDocsProjectCatalog();
const project = docsCatalogProject(docsProjectCatalog, Astro.params.slug!);
if (!project) {
  return Astro.redirect(withBasePath("/docs/"));
}

let generatedDocHtml: string | undefined;
try {
  generatedDocHtml = await readFile(join(process.cwd(), "src", "content", "generated-docs", `${project.slug}.html`), "utf8");
  generatedDocHtml = enhanceGeneratedContentHtml(generatedDocHtml);
} catch {
  generatedDocHtml = undefined;
}

const canonicalUrl = canonicalSurfaceUrl("docs", `/docs/${project.slug}/`);
const generatedDocSections = generatedDocHtml ? extractGeneratedDocSections(generatedDocHtml) : [];
const contentSections = generatedDocSections.length ? generatedDocSections : project.sections.map((section) => ({
  id: section.id,
  label: `${section.number}. ${section.title}`,
  depth: 1,
  parentId: undefined
}));
const sidebarSections = contentSections;
const activeProjectSections = contentSections.filter((section) => section.depth === 1);

function extractGeneratedDocSections(html: string) {
  const sections: Array<{ id: string; label: string; depth: number; parentId?: string }> = [];
  const headingPattern = /<h([1-6])\b([^>]*)\bid="([^"]+)"([^>]*)>([\s\S]*?)<\/h\1>/g;
  let activeTopLevelId: string | undefined;
  for (const match of html.matchAll(headingPattern)) {
    const depth = Number(match[1]);
    const label = generatedHtmlLabel(match[5]);
    if (label) {
      if (depth === 1) {
        activeTopLevelId = match[3];
      }
      sections.push({
        id: match[3],
        label,
        depth,
        parentId: depth === 1 ? undefined : activeTopLevelId
      });
    }
    if (sections.length >= 600) {
      break;
    }
  }
  return sections;
}
---

<WebLayout title={`${project.displayName} Docs`} surface="docs" canonicalUrl={canonicalUrl}>
  <DocsShell
    projectCatalog={docsProjectCatalog}
    activeSlug={project.slug}
    activeSections={activeProjectSections}
  >
    <article class:list={[
      "grid w-full grid-cols-1 py-6",
      generatedDocHtml ? "px-4 md:px-12 xl:grid-cols-[minmax(0,1fr)_260px] xl:gap-8" : "px-4 md:px-5 xl:grid-cols-[minmax(0,1fr)_240px] xl:px-0"
    ]}>
      <div class:list={["min-w-0", !generatedDocHtml && "xl:px-14"]}>
        {!generatedDocHtml && (
          <header id={`${project.slug}-docs`} class="mb-7 scroll-mt-24">
            <div class="mb-4 flex items-center gap-3">
              <IconBadge name={project.icon} size="lg" />
              <Badge variant="secondary">{project.primaryCategory}</Badge>
            </div>
            <h1 class="text-3xl font-bold tracking-tight md:text-4xl">{project.displayName}</h1>
            <p class="mt-3 max-w-2xl text-base leading-7 text-muted-foreground">{project.longDescription}</p>
            <ProjectReferenceLinks references={project.references} />
          </header>
        )}
        {generatedDocHtml ? (
          <>
            <div class="generated-docs-content" data-generated-docs set:html={generatedDocHtml} />
            <GeneratedDocsStaticEnhancer />
          </>
        ) : (
          <div class="grid gap-8 text-base leading-7">
            {project.sections.map((section) => (
              <section id={section.id} class="scroll-mt-24">
                <h2 class="text-2xl font-semibold tracking-tight">{section.number}. {section.title}</h2>
                <p class="mt-3 max-w-3xl text-muted-foreground">{section.summary}</p>
                <Card className="mt-4">
                  <CardHeader>
                    <CardTitle className="text-base">{section.title}</CardTitle>
                    <CardDescription>{project.displayName} reference entry.</CardDescription>
                  </CardHeader>
                  <CardContent>
                    <p>
                      This lightweight docs page is ready for generated module documentation, API references,
                      configuration pages, and search entries while preserving the shared Micronaut web styling.
                    </p>
                    <div class="mt-4 overflow-hidden rounded-lg border bg-muted/50">
                      <pre class="overflow-x-auto p-4 text-sm leading-7"><code>{`micronaut.project=${project.slug}
micronaut.module=${project.module}
micronaut.category=${project.primaryCategory}`}</code></pre>
                    </div>
                  </CardContent>
                </Card>
              </section>
            ))}
          </div>
        )}
      </div>
      {sidebarSections.length > 0 && (
        <aside class="hidden xl:block" aria-label="In this section">
          <div class="sticky top-[calc(var(--topbar-height)+24px)] grid max-h-[calc(100vh-var(--topbar-height)-48px)] gap-1.5 overflow-y-auto pb-7 pl-2.5 pr-6 text-[0.82rem] [scrollbar-width:thin]" data-docs-scroll-container>
            <h2 class="font-medium">In this section</h2>
            <Separator className="opacity-70" />
            {sidebarSections.map((section) => (
              <a
                href={`#${section.id}`}
                data-docs-scroll-link
                class:list={[
                  "relative rounded-md py-1.5 pr-2 leading-5 break-words text-muted-foreground no-underline hover:bg-accent hover:text-accent-foreground data-[active=true]:bg-accent data-[active=true]:font-medium data-[active=true]:text-foreground data-[active=true]:before:absolute data-[active=true]:before:bottom-[7px] data-[active=true]:before:left-[-11px] data-[active=true]:before:top-[7px] data-[active=true]:before:w-0.5 data-[active=true]:before:rounded-full data-[active=true]:before:bg-brand data-[active=true]:before:content-['']",
                  section.depth <= 1 && "pl-2",
                  section.depth === 2 && "pl-4 text-[0.8rem]",
                  section.depth === 3 && "pl-6 text-[0.78rem]",
                  section.depth >= 4 && "pl-8 text-[0.76rem]"
                ]}
              >
                {section.label}
              </a>
            ))}
          </div>
        </aside>
      )}
    </article>
  </DocsShell>
</WebLayout>

{generatedDocHtml && (
  <script type="module" src={generatedDocsHashAlignerUrl}></script>
)}
