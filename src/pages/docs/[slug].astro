---
import { readFile } from "node:fs/promises";
import { join } from "node:path";

import WebLayout from "@/layouts/WebLayout.astro";
import { Badge } from "@/components/ui/badge";
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle
} from "@/components/ui/card";
import { Separator } from "@/components/ui/separator";
import { DocsShell } from "@/components/web/docs-shell";
import GeneratedDocsEnhancer from "@/components/web/generated-docs-enhancer.astro";
import { IconBadge } from "@/components/web/icon-badge";
import { ProjectReferenceLinks } from "@/components/web/project-reference-links";
import { enhanceGeneratedContentHtml, generatedHtmlLabel } from "@/lib/generated-docs-html";
import { micronautProtocol, projectBySlug } from "@/lib/protocol";

export function getStaticPaths() {
  return micronautProtocol.docs.projects.map((project) => ({
    params: { slug: project.slug }
  }));
}

const project = projectBySlug(Astro.params.slug!);
if (!project) {
  return Astro.redirect("/docs/");
}

let generatedDocHtml: string | undefined;
try {
  generatedDocHtml = await readFile(join(process.cwd(), "src", "content", "generated-docs", `${project.slug}.html`), "utf8");
  generatedDocHtml = enhanceGeneratedContentHtml(generatedDocHtml);
} catch {
  generatedDocHtml = undefined;
}

const generatedDocSections = generatedDocHtml ? extractGeneratedDocSections(generatedDocHtml) : [];
const contentSections = generatedDocSections.length ? generatedDocSections : project.sections.map((section) => ({
  id: section.id,
  label: `${section.number}. ${section.title}`,
  depth: 1,
  parentId: undefined
}));
const sidebarSections = contentSections.filter((section) => section.depth === 1);

function extractGeneratedDocSections(html: string) {
  const sections: Array<{ id: string; label: string; depth: number; parentId?: string }> = [];
  const headingPattern = /<div class="guide-section-heading">\s*<h([12]) id="([^"]+)"><a class="anchor" href="#[^"]+"[^>]*><\/a>([\s\S]*?)<\/h\1>/g;
  let activeTopLevelId: string | undefined;
  for (const match of html.matchAll(headingPattern)) {
    const depth = Number(match[1]);
    const label = generatedHtmlLabel(match[3]);
    if (label) {
      if (depth === 1) {
        activeTopLevelId = match[2];
      }
      sections.push({
        id: match[2],
        label,
        depth,
        parentId: depth === 1 ? undefined : activeTopLevelId
      });
    }
    if (sections.length >= 600) {
      break;
    }
  }
  return sections;
}
---

<WebLayout title={`${project.displayName} Docs`} surface="docs" hideHeader>
  <DocsShell activeSlug={project.slug} activeSections={sidebarSections} client:idle>
    <article class:list={[
      "grid w-full grid-cols-1 py-6",
      generatedDocHtml ? "px-4 md:px-12 xl:grid-cols-[minmax(0,1fr)_260px] xl:gap-8" : "px-4 md:px-5 xl:grid-cols-[minmax(0,1fr)_240px] xl:px-0"
    ]}>
      <div class:list={["min-w-0", !generatedDocHtml && "xl:px-14"]}>
        {!generatedDocHtml && (
          <header class="mb-7">
            <div class="mb-4 flex items-center gap-3">
              <IconBadge name={project.icon} size="lg" />
              <Badge variant="secondary">{project.primaryCategory}</Badge>
            </div>
            <h1 class="text-3xl font-bold tracking-tight md:text-4xl">{project.displayName}</h1>
            <p class="mt-3 max-w-2xl text-base leading-7 text-muted-foreground">{project.longDescription}</p>
            <ProjectReferenceLinks references={project.references} />
          </header>
        )}
        {generatedDocHtml ? (
          <>
            <div class="generated-docs-content" data-generated-docs set:html={generatedDocHtml} />
            <GeneratedDocsEnhancer />
          </>
        ) : (
          <div class="grid gap-8 text-base leading-7">
            {project.sections.map((section) => (
              <section id={section.id} class="scroll-mt-24">
                <h2 class="text-2xl font-semibold tracking-tight">{section.number}. {section.title}</h2>
                <p class="mt-3 max-w-3xl text-muted-foreground">{section.summary}</p>
                <Card className="mt-4">
                  <CardHeader>
                    <CardTitle className="text-base">{section.title}</CardTitle>
                    <CardDescription>{project.displayName} reference entry.</CardDescription>
                  </CardHeader>
                  <CardContent>
                    <p>
                      This lightweight docs page is ready for generated module documentation, API references,
                      configuration pages, and search entries while preserving the shared Micronaut web styling.
                    </p>
                    <div class="mt-4 overflow-hidden rounded-lg border bg-muted/50">
                      <pre class="overflow-x-auto p-4 text-sm leading-7"><code>{`micronaut.project=${project.slug}
micronaut.module=${project.module}
micronaut.category=${project.primaryCategory}`}</code></pre>
                    </div>
                  </CardContent>
                </Card>
              </section>
            ))}
          </div>
        )}
      </div>
      {contentSections.length > 0 && (
        <aside class="hidden xl:block" aria-label="In this section">
          <div class="sticky top-24 grid gap-1.5 pl-2.5 pr-6 text-[0.82rem]">
            <h2 class="font-medium">In this section</h2>
            <Separator className="opacity-70" />
            {contentSections.map((section) => (
              <a href={`#${section.id}`} data-docs-scroll-link data-docs-section-depth={section.depth} data-docs-section-parent={section.parentId || ""} class:list={[
                "rounded-md px-2 py-1.5 leading-5 text-muted-foreground no-underline hover:bg-accent hover:text-accent-foreground data-[active=true]:bg-accent data-[active=true]:text-accent-foreground",
                section.depth > 1 && "pl-5 text-xs"
              ]}>
                {section.label}
              </a>
            ))}
          </div>
        </aside>
      )}
    </article>
  </DocsShell>
</WebLayout>

{generatedDocHtml && (
  <script is:inline>
    (() => {
      const alignHash = () => {
        if (!window.location.hash) {
          return;
        }
        const id = decodeURIComponent(window.location.hash.slice(1));
        const target = document.getElementById(id);
        if (!target || !target.closest("[data-generated-docs]")) {
          return;
        }
        const scrollPaddingTop = Number.parseFloat(getComputedStyle(document.documentElement).scrollPaddingTop) || 80;
        const top = target.getBoundingClientRect().top + window.scrollY - scrollPaddingTop;
        window.scrollTo({ top: Math.max(0, top) });
      };

      const scheduleAlignHash = () => {
        requestAnimationFrame(alignHash);
        window.setTimeout(alignHash, 50);
        window.setTimeout(alignHash, 250);
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", scheduleAlignHash, { once: true });
      } else {
        scheduleAlignHash();
      }
      window.addEventListener("load", scheduleAlignHash, { once: true });
      window.addEventListener("astro:hydrate", scheduleAlignHash);
      window.addEventListener("hashchange", scheduleAlignHash);
    })();
  </script>
)}

<style is:global>
  .generated-docs-content {
    min-width: 0;
    color: var(--foreground);
    font-size: 1rem;
    line-height: 1.6;
    overflow-wrap: break-word;
  }

  .generated-docs-content > style {
    display: none;
  }

  .generated-docs-content .project h1 {
    margin: 0.9rem 0 1.85rem;
    font-size: clamp(2rem, 3.4vw, 2.5rem);
    line-height: 1.18;
    font-weight: 700;
    letter-spacing: 0;
  }

  .generated-docs-content .guide-section-heading {
    position: relative;
    min-width: 0;
    margin-top: 2.25rem;
  }

  .generated-docs-content .project + .guide-section-heading {
    margin-top: 0;
  }

  .generated-docs-content .guide-section-heading h1,
  .generated-docs-content .guide-section-heading h2 {
    margin: 0 0 0.9rem;
    padding-right: 2.25rem;
    scroll-margin-top: 5rem;
    font-weight: 700;
    letter-spacing: 0;
  }

  .generated-docs-content .guide-section-heading h1 {
    font-size: clamp(2rem, 3.1vw, 2rem);
    line-height: 1.18;
  }

  .generated-docs-content .guide-section-heading h2 {
    font-size: clamp(1.55rem, 2.2vw, 1.8rem);
    line-height: 1.22;
  }

  .generated-docs-content .guide-section-heading .anchor {
    color: inherit;
    text-decoration: none;
  }

  .generated-docs-content .contribute-btn {
    position: absolute;
    right: 0;
    top: 0.2rem;
    display: grid;
    width: 1.75rem;
    height: 1.75rem;
    place-items: center;
    border-radius: 0.375rem;
    color: var(--muted-foreground);
    opacity: 0;
    text-decoration: none;
    transition:
      background-color 150ms ease,
      color 150ms ease,
      opacity 150ms ease;
  }

  .generated-docs-content .guide-section-heading:hover .contribute-btn,
  .generated-docs-content .contribute-btn:focus-visible {
    opacity: 1;
  }

  .generated-docs-content .contribute-btn:hover {
    background: var(--accent);
    color: var(--accent-foreground);
  }

  .generated-docs-content .button-icon {
    width: 1rem;
    height: 1rem;
  }

  .generated-docs-content .paragraph p {
    margin: 0 0 1.25rem;
  }

  .generated-docs-content :where(.sect2, .sect3, .sect4, .sect5) {
    min-width: 0;
    margin-top: 1.55rem;
  }

  .generated-docs-content :where(.sect2, .sect3, .sect4, .sect5) > :where(h3, h4, h5, h6) {
    margin: 0 0 0.8rem;
    scroll-margin-top: 5rem;
    font-weight: 700;
    letter-spacing: 0;
  }

  .generated-docs-content .sect2 > h3 {
    font-size: 1.35rem;
    line-height: 1.3;
  }

  .generated-docs-content .sect3 > h4 {
    font-size: 1.15rem;
    line-height: 1.35;
  }

  .generated-docs-content .sect4 > h5,
  .generated-docs-content .sect5 > h6 {
    font-size: 1rem;
    line-height: 1.4;
  }

  .generated-docs-content :where(.ulist, .olist) {
    margin: 0 0 1.25rem;
  }

  .generated-docs-content .ulist ul {
    margin: 0;
    padding-left: 1.45rem;
    list-style: disc;
  }

  .generated-docs-content .olist ol {
    margin: 0;
    padding-left: 1.45rem;
    list-style: decimal;
  }

  .generated-docs-content li + li {
    margin-top: 0.8rem;
  }

  .generated-docs-content li > p {
    margin: 0;
  }

  .generated-docs-content a {
    color: var(--brand);
    text-decoration: none;
  }

  .generated-docs-content a:hover {
    text-decoration: underline;
  }

  .generated-docs-content :not(pre) > code {
    border-radius: 0.25rem;
    background: var(--muted);
    padding: 0.05rem 0.25rem;
    color: var(--foreground);
    font-size: 0.9em;
  }

  .generated-docs-content :where(.listingblock, .literalblock, .exampleblock, .sidebarblock, .openblock, .admonitionblock) {
    min-width: 0;
    margin: 1.25rem 0;
  }

  .generated-docs-content :where(.listingblock, .literalblock) pre {
    max-width: 100%;
    overflow-x: auto;
  }

  .generated-docs-content .admonitionblock {
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: var(--muted);
  }

  .generated-docs-content .admonitionblock table {
    width: 100%;
    border-collapse: collapse;
  }

  .generated-docs-content .admonitionblock td.icon {
    width: 4.25rem;
    padding: 1rem 0.75rem;
    color: var(--muted-foreground);
    font-size: 0.72rem;
    font-weight: 700;
    text-align: center;
    text-transform: uppercase;
    vertical-align: top;
  }

  .generated-docs-content .admonitionblock td.content {
    padding: 1rem 1rem 1rem 0;
    vertical-align: top;
  }

  .generated-docs-content .admonitionblock td.content > :last-child,
  .generated-docs-content .admonitionblock td.content > :last-child p {
    margin-bottom: 0;
  }

  .generated-docs-content table.tableblock {
    width: 100%;
    margin: 1.25rem 0;
    border-collapse: collapse;
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .generated-docs-content table.tableblock caption {
    margin-bottom: 0.55rem;
    color: var(--foreground);
    font-weight: 700;
    text-align: left;
  }

  .generated-docs-content table.tableblock :where(th, td) {
    border: 1px solid var(--border);
    padding: 0.65rem 0.75rem;
    vertical-align: top;
  }

  .generated-docs-content table.tableblock th {
    background: var(--muted);
    font-weight: 700;
  }

  .generated-docs-content img {
    max-width: 100%;
    height: auto;
  }

  .generated-docs-content .colist {
    margin: -0.4rem 0 1.25rem;
    color: var(--muted-foreground);
    font-size: 0.9rem;
  }
</style>
