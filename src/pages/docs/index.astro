---
import WebLayout from "@/layouts/WebLayout.astro";
import { DocsShell } from "@/components/web/docs-shell";
import { IconBadge } from "@/components/web/icon-badge";
import { ProjectCard } from "@/components/web/project-card";
import { docsCatalogProjectsByCategory, docsProjectCatalog } from "@/lib/protocol";
---

<WebLayout title="Micronaut Docs" surface="docs" hideHeader>
  <DocsShell client:idle>
    <section class="mx-auto grid w-full max-w-[1346px] gap-6 px-5 py-7 md:px-6">
      <h1 class="sr-only">Micronaut Docs</h1>
      <p class="m-0 max-w-none text-base leading-7 text-muted-foreground">
        Micronaut Framework is a modern JVM framework for modular applications and services with fast startup, low memory use,
        and compile-time dependency injection. These docs collect the core framework and companion modules in one place
        for aligned versions, guides, APIs, and configuration references.
      </p>
      <div class="grid gap-6">
        {docsProjectCatalog.categories.map((category) => {
          const projects = docsCatalogProjectsByCategory(category);
          if (!projects.length) return null;
          return (
            <section id={category.slug} class="min-w-0 scroll-mt-24">
              <div class="mb-2 flex items-start justify-between gap-3 py-2">
                <div class="grid min-w-0 grid-cols-[34px_minmax(0,1fr)] items-start gap-2.5">
                  <IconBadge name={category.icon} size="sm" />
                  <div class="min-w-0">
                    <h2 class="m-0 text-[1.04rem] font-semibold leading-snug tracking-normal">{category.name}</h2>
                    <p class="mt-1 max-w-[68ch] text-[0.86rem] leading-5 text-muted-foreground">{category.description}</p>
                  </div>
                </div>
              </div>
              <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
                {projects.map((project) => <ProjectCard project={project} />)}
              </div>
            </section>
          );
        })}
      </div>
    </section>
  </DocsShell>
</WebLayout>
