async function fetchJson<T>(path: string): Promise<T> {
  const response = await fetch(`${API_BASE_URL}${path}`);
  if (!response.ok) {
    throw new Error(`Launch API ${path} returned ${response.status}`);
  }
  return response.json() as Promise<T>;
}

async function loadLaunchData(): Promise<LaunchInitialData> {
  try {
    const [selectOptions, applicationTypes, versions] = await Promise.all([
      fetchJson<SelectOptionsResponse>("/select-options"),
      fetchJson<ApplicationTypesResponse>("/application-types"),
      fetchJson<VersionsResponse>("/versions")
    ]);
    const featuresEntries = await Promise.all(
      applicationTypes.types.map(async (type) => {
        const response = await fetchJson<FeaturesResponse>(`/application-types/${type.name}/features`);
        return [type.name, response.features] as const;
      })
    );

    return {
      apiBaseUrl: API_BASE_URL,
      generatedAt: new Date().toISOString(),
      micronautVersion: versions.versions["micronaut.version"] ?? versions.versions["micronaut.core.version"] ?? fallbackData.micronautVersion,
      source: "live",
      selectOptions,
      applicationTypes: applicationTypes.types,
      featuresByType: Object.fromEntries(featuresEntries)
    };
  } catch {
    return fallbackData;
  }
}

const initialData = await loadLaunchData();
---

<WebLayout
  title="Micronaut Launch"
  description="Configure and generate a Micronaut project with the official Micronaut Starter backend"
  surface="launch"
>
  <LaunchApp initialData={initialData} client:load />
</WebLayout>
