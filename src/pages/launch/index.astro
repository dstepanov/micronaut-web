---
import WebLayout from "@/layouts/WebLayout.astro";
import { LaunchApp, type LaunchInitialData } from "@/components/web/launch-app";

const API_BASE_URL = "https://launch.micronaut.io";

type SelectOptionsResponse = LaunchInitialData["selectOptions"];
type ApplicationTypesResponse = { types: LaunchInitialData["applicationTypes"] };
type FeaturesResponse = { features: LaunchInitialData["featuresByType"][string] };

const fallbackData: LaunchInitialData = {
  apiBaseUrl: API_BASE_URL,
  generatedAt: new Date().toISOString(),
  source: "fallback",
  selectOptions: {
    type: {
      options: [
        { title: "Micronaut Application", description: "A Micronaut Application", name: "default", value: "DEFAULT", label: "Micronaut Application" },
        { title: "Micronaut CLI Application", description: "A Command Line Application", name: "cli", value: "CLI", label: "Command Line Application" },
        { title: "Micronaut Serverless Function", description: "A Function Application for Serverless", name: "function", value: "FUNCTION", label: "Function Application for Serverless" },
        { title: "Micronaut gRPC Application", description: "A gRPC Application", name: "grpc", value: "GRPC", label: "gRPC Application" },
        { title: "Micronaut Messaging Application", description: "A Messaging-Driven Application", name: "messaging", value: "MESSAGING", label: "Messaging-Driven Application" }
      ],
      defaultOption: { title: "Micronaut Application", description: "A Micronaut Application", name: "default", value: "DEFAULT", label: "Micronaut Application" }
    },
    jdkVersion: {
      options: [{ description: "JDK_25", name: "JDK_25", value: "JDK_25", label: "25" }],
      defaultOption: { description: "JDK_25", name: "JDK_25", value: "JDK_25", label: "25" }
    },
    lang: {
      options: [
        { extension: "java", description: "java", name: "java", value: "JAVA", label: "Java", defaults: { test: "JUNIT", build: "GRADLE_KOTLIN" } },
        { extension: "groovy", description: "groovy", name: "groovy", value: "GROOVY", label: "Groovy", defaults: { test: "SPOCK", build: "GRADLE_KOTLIN" } },
        { extension: "kt", description: "kotlin", name: "kotlin", value: "KOTLIN", label: "Kotlin", defaults: { test: "JUNIT", build: "GRADLE_KOTLIN" } }
      ],
      defaultOption: { extension: "java", description: "java", name: "java", value: "JAVA", label: "Java", defaults: { test: "JUNIT", build: "GRADLE_KOTLIN" } }
    },
    test: {
      options: [
        { description: "JUnit", name: "junit", value: "JUNIT", label: "JUnit" },
        { description: "Spock", name: "spock", value: "SPOCK", label: "Spock" },
        { description: "Kotest", name: "kotest", value: "KOTEST", label: "Kotest" }
      ],
      defaultOption: { description: "JUnit", name: "junit", value: "JUNIT", label: "JUnit" }
    },
    build: {
      options: [
        { label: "Gradle", description: "Gradle", value: "GRADLE" },
        { label: "Gradle Kotlin", description: "Gradle Kotlin", value: "GRADLE_KOTLIN" },
        { label: "Maven", description: "Maven", value: "MAVEN" }
      ],
      defaultOption: { label: "Gradle Kotlin", description: "Gradle Kotlin", value: "GRADLE_KOTLIN" }
    }
  },
  applicationTypes: [
    { title: "Micronaut Application", description: "A Micronaut Application", name: "default", value: "DEFAULT", label: "Micronaut Application" },
    { title: "Micronaut CLI Application", description: "A Command Line Application", name: "cli", value: "CLI", label: "Command Line Application" },
    { title: "Micronaut Serverless Function", description: "A Function Application for Serverless", name: "function", value: "FUNCTION", label: "Function Application for Serverless" },
    { title: "Micronaut gRPC Application", description: "A gRPC Application", name: "grpc", value: "GRPC", label: "gRPC Application" },
    { title: "Micronaut Messaging Application", description: "A Messaging-Driven Application", name: "messaging", value: "MESSAGING", label: "Messaging-Driven Application" }
  ],
  featuresByType: {
    default: [
      { name: "serialization-jackson", title: "Micronaut Serialization Jackson Core", description: "Adds support using Micronaut Serialization with Jackson Core", category: "API", preview: false, community: false },
      { name: "management", title: "Micronaut Management", description: "Adds management and monitoring endpoints", category: "Management", preview: false, community: false },
      { name: "openapi", title: "OpenAPI Support", description: "Adds support for OpenAPI (Swagger)", category: "API", preview: false, community: false },
      { name: "data-jdbc", title: "Micronaut Data JDBC", description: "Adds support for Micronaut Data JDBC", category: "Database", preview: false, community: false },
      { name: "validation", title: "Micronaut Validation", description: "Adds support for Micronaut Validation", category: "Validation", preview: false, community: false }
    ]
  }
};

async function fetchJson<T>(path: string): Promise<T> {
  const response = await fetch(`${API_BASE_URL}${path}`);
  if (!response.ok) {
    throw new Error(`Launch API ${path} returned ${response.status}`);
  }
  return response.json() as Promise<T>;
}

async function loadLaunchData(): Promise<LaunchInitialData> {
  try {
    const [selectOptions, applicationTypes] = await Promise.all([
      fetchJson<SelectOptionsResponse>("/select-options"),
      fetchJson<ApplicationTypesResponse>("/application-types")
    ]);
    const featuresEntries = await Promise.all(
      applicationTypes.types.map(async (type) => {
        const response = await fetchJson<FeaturesResponse>(`/application-types/${type.name}/features`);
        return [type.name, response.features] as const;
      })
    );

    return {
      apiBaseUrl: API_BASE_URL,
      generatedAt: new Date().toISOString(),
      source: "live",
      selectOptions,
      applicationTypes: applicationTypes.types,
      featuresByType: Object.fromEntries(featuresEntries)
    };
  } catch {
    return fallbackData;
  }
}

const initialData = await loadLaunchData();
---

<WebLayout
  title="Micronaut Launch"
  description="Configure and generate a Micronaut project with the official Micronaut Starter backend"
  surface="launch"
>
  <LaunchApp initialData={initialData} client:load />
</WebLayout>
