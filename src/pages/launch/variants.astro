---
import WebLayout from "@/layouts/WebLayout.astro";
import { LaunchVariantLab } from "@/components/web/launch-variant-lab";
import type { LaunchInitialData } from "@/components/web/launch-app";

const API_BASE_URL = "https://launch.micronaut.io";

type SelectOptionsResponse = LaunchInitialData["selectOptions"];
type ApplicationTypesResponse = { types: LaunchInitialData["applicationTypes"] };
type FeaturesResponse = { features: LaunchInitialData["featuresByType"][string] };
type VersionsResponse = { versions: Record<string, string> };

const fallbackFeatures: LaunchInitialData["featuresByType"][string] = [
  { name: "serialization-jackson", title: "Micronaut Serialization Jackson", description: "JSON serialization for request and response payloads.", category: "Serialization", preview: false, community: false },
  { name: "validation", title: "Micronaut Validation", description: "Bean validation and generated validation wiring.", category: "Validation", preview: false, community: false },
  { name: "openapi", title: "OpenAPI Support", description: "OpenAPI and Swagger documentation support.", category: "API", preview: false, community: false },
  { name: "management", title: "Micronaut Management", description: "Health, info, and management endpoints.", category: "Management", preview: false, community: false },
  { name: "problem-json", title: "Problem JSON", description: "Structured application/problem+json error responses.", category: "API", preview: false, community: false },
  { name: "http-client", title: "Micronaut HTTP Client", description: "Outbound HTTP client support.", category: "Client", preview: false, community: false },
  { name: "jdbc-hikari", title: "JDBC Hikari", description: "JDBC connection pooling with HikariCP.", category: "Database", preview: false, community: false },
  { name: "postgres", title: "PostgreSQL Driver", description: "PostgreSQL database driver.", category: "Database", preview: false, community: false },
  { name: "mysql", title: "MySQL Driver", description: "MySQL database driver.", category: "Database", preview: false, community: false },
  { name: "h2", title: "H2 Database", description: "In-memory database for development and tests.", category: "Database", preview: false, community: false },
  { name: "oracle", title: "Oracle Database Driver", description: "Oracle database driver.", category: "Database", preview: false, community: false },
  { name: "data-jdbc", title: "Micronaut Data JDBC", description: "Compile-time repositories for JDBC.", category: "Database", preview: false, community: false },
  { name: "data-jpa", title: "Micronaut Data JPA", description: "Hibernate and JPA persistence support.", category: "Database", preview: false, community: false },
  { name: "data-r2dbc", title: "Micronaut Data R2DBC", description: "Reactive relational database connectivity.", category: "Database", preview: false, community: false },
  { name: "data-mongodb", title: "Micronaut Data MongoDB", description: "MongoDB repository support.", category: "Database", preview: false, community: false },
  { name: "flyway", title: "Flyway Migration", description: "Database schema migration support.", category: "Database", preview: false, community: false },
  { name: "liquibase", title: "Liquibase Migration", description: "Database schema change management.", category: "Database", preview: false, community: false },
  { name: "testcontainers", title: "Testcontainers", description: "Containerized dependencies for tests.", category: "Testing", preview: false, community: false },
  { name: "kafka", title: "Kafka", description: "Kafka messaging support.", category: "Messaging", preview: false, community: false },
  { name: "rabbitmq", title: "RabbitMQ", description: "RabbitMQ messaging support.", category: "Messaging", preview: false, community: false },
  { name: "micrometer", title: "Micrometer", description: "Metrics instrumentation support.", category: "Observability", preview: false, community: false },
  { name: "security-jwt", title: "JWT Security", description: "JWT authentication and authorization support.", category: "Security", preview: false, community: false },
  { name: "dockerfile", title: "Dockerfile", description: "Container image build file generation.", category: "Cloud", preview: false, community: false },
  { name: "mcp-http", title: "MCP HTTP Server", description: "Model Context Protocol HTTP server support.", category: "MCP", preview: false, community: false },
  { name: "langchain4j-openai", title: "LangChain4j OpenAI", description: "LangChain4j integration for OpenAI-backed services.", category: "AI", preview: false, community: false }
];

const fallbackData: LaunchInitialData = {
  apiBaseUrl: API_BASE_URL,
  generatedAt: new Date().toISOString(),
  micronautVersion: "5.0.0",
  source: "fallback",
  selectOptions: {
    type: {
      options: [
        { title: "Micronaut Application", description: "A Micronaut Application", name: "default", value: "DEFAULT", label: "Micronaut Application" },
        { title: "Micronaut CLI Application", description: "A command-line application", name: "cli", value: "CLI", label: "Command Line Application" },
        { title: "Micronaut Serverless Function", description: "A serverless function", name: "function", value: "FUNCTION", label: "Function Application" },
        { title: "Micronaut Messaging Application", description: "A messaging-driven application", name: "messaging", value: "MESSAGING", label: "Messaging Application" }
      ],
      defaultOption: { title: "Micronaut Application", description: "A Micronaut Application", name: "default", value: "DEFAULT", label: "Micronaut Application" }
    },
    jdkVersion: {
      options: [
        { description: "JDK_17", name: "JDK_17", value: "JDK_17", label: "17" },
        { description: "JDK_21", name: "JDK_21", value: "JDK_21", label: "21" },
        { description: "JDK_25", name: "JDK_25", value: "JDK_25", label: "25" }
      ],
      defaultOption: { description: "JDK_21", name: "JDK_21", value: "JDK_21", label: "21" }
    },
    lang: {
      options: [
        { extension: "java", description: "java", name: "java", value: "JAVA", label: "Java", defaults: { test: "JUNIT", build: "GRADLE_KOTLIN" } },
        { extension: "kt", description: "kotlin", name: "kotlin", value: "KOTLIN", label: "Kotlin", defaults: { test: "JUNIT", build: "GRADLE_KOTLIN" } },
        { extension: "groovy", description: "groovy", name: "groovy", value: "GROOVY", label: "Groovy", defaults: { test: "SPOCK", build: "GRADLE_KOTLIN" } }
      ],
      defaultOption: { extension: "java", description: "java", name: "java", value: "JAVA", label: "Java", defaults: { test: "JUNIT", build: "GRADLE_KOTLIN" } }
    },
    test: {
      options: [
        { description: "JUnit", name: "junit", value: "JUNIT", label: "JUnit" },
        { description: "Spock", name: "spock", value: "SPOCK", label: "Spock" },
        { description: "Kotest", name: "kotest", value: "KOTEST", label: "Kotest" }
      ],
      defaultOption: { description: "JUnit", name: "junit", value: "JUNIT", label: "JUnit" }
    },
    build: {
      options: [
        { label: "Gradle", description: "Gradle", value: "GRADLE", name: "gradle" },
        { label: "Gradle Kotlin", description: "Gradle Kotlin", value: "GRADLE_KOTLIN", name: "gradle_kotlin" },
        { label: "Maven", description: "Maven", value: "MAVEN", name: "maven" }
      ],
      defaultOption: { label: "Gradle Kotlin", description: "Gradle Kotlin", value: "GRADLE_KOTLIN", name: "gradle_kotlin" }
    }
  },
  applicationTypes: [
    { title: "Micronaut Application", description: "A Micronaut Application", name: "default", value: "DEFAULT", label: "Micronaut Application" },
    { title: "Micronaut CLI Application", description: "A command-line application", name: "cli", value: "CLI", label: "Command Line Application" },
    { title: "Micronaut Serverless Function", description: "A serverless function", name: "function", value: "FUNCTION", label: "Function Application" },
    { title: "Micronaut Messaging Application", description: "A messaging-driven application", name: "messaging", value: "MESSAGING", label: "Messaging Application" }
  ],
  featuresByType: {
    default: fallbackFeatures,
    cli: fallbackFeatures,
    function: fallbackFeatures,
    messaging: fallbackFeatures
  }
};

async function fetchJson<T>(path: string): Promise<T> {
  const response = await fetch(`${API_BASE_URL}${path}`);
  if (!response.ok) {
    throw new Error(`Launch API ${path} returned ${response.status}`);
  }
  return response.json() as Promise<T>;
}

async function loadLaunchData(): Promise<LaunchInitialData> {
  try {
    const [selectOptions, applicationTypes, versions] = await Promise.all([
      fetchJson<SelectOptionsResponse>("/select-options"),
      fetchJson<ApplicationTypesResponse>("/application-types"),
      fetchJson<VersionsResponse>("/versions")
    ]);
    const featuresEntries = await Promise.all(
      applicationTypes.types.map(async (type) => {
        const response = await fetchJson<FeaturesResponse>(`/application-types/${type.name}/features`);
        return [type.name, response.features] as const;
      })
    );

    return {
      apiBaseUrl: API_BASE_URL,
      generatedAt: new Date().toISOString(),
      micronautVersion: versions.versions["micronaut.version"] ?? versions.versions["micronaut.core.version"] ?? fallbackData.micronautVersion,
      source: "live",
      selectOptions,
      applicationTypes: applicationTypes.types,
      featuresByType: Object.fromEntries(featuresEntries)
    };
  } catch {
    return fallbackData;
  }
}

const initialData = await loadLaunchData();
---

<WebLayout
  title="Micronaut Launch UX Implementations"
  description="Ten alternative Micronaut Launch user experience implementations from quick presets through advanced power-user configuration."
  surface="launch"
>
  <LaunchVariantLab initialData={initialData} client:load />
</WebLayout>
