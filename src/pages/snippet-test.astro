---
import { Badge } from "@/components/ui/badge";
import GeneratedDocsEnhancer from "@/components/web/generated-docs-enhancer.astro";
import GeneratedDocsPropertiesFallback from "@/components/web/generated-docs-properties-fallback.astro";
import { SnippetTestGallery } from "@/components/web/snippet-test-gallery";
import { componentCodeVariants, componentTerminalVariants, dependencyVariants } from "@/components/web/snippet-test-data";
import WebLayout from "@/layouts/WebLayout.astro";
import { highlightCodeSnippetHtml } from "@/lib/docs-code-highlighting";
import { snippetVariantHighlightKey } from "@/lib/snippet-highlight-key";

const snippetTestHighlightGroups = [
  { id: "snippet-test-controller", variants: componentCodeVariants },
  { id: "snippet-test-terminal", variants: componentTerminalVariants },
  { id: "snippet-test-dependency", variants: dependencyVariants }
];
const snippetTestHighlightedHtmlByKey = Object.fromEntries(
  await Promise.all(
    snippetTestHighlightGroups.flatMap((group) =>
      group.variants.map(async (variant) => [
        snippetVariantHighlightKey(group.id, variant.language),
        await highlightCodeSnippetHtml(variant.code, variant.highlighterLanguage || variant.language)
      ] as const)
    )
  )
);
const generatedDocsFixture = `
<div class="project">
  <h1>Snippet Fixture</h1>
</div>

<div data-snippet-fixture="generated-multi">
  <div class="listingblock docs-code-block multi-language-sample" data-lang="java">
    <div class="title">Controller callout sample</div>
    <div class="content">
      <pre class="shiki shiki-themes github-light-default github-dark-default" style="background-color:#ffffff;--shiki-dark-bg:#0d1117;color:#1f2328;--shiki-dark:#e6edf3" tabindex="0"><code class="language-java shiki-code" data-lang="java"><span class="line"><span style="color:#1F2328;--shiki-dark:#E6EDF3">@</span><span style="color:#CF222E;--shiki-dark:#FF7B72">Controller</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">(</span><span style="color:#0A3069;--shiki-dark:#A5D6FF">"/hello"</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">) </span><span style="color:#6E7781;--shiki-dark:#8B949E">// <i class="conum" data-value="1"></i></span></span>
<span class="line"><span style="color:#CF222E;--shiki-dark:#FF7B72">class</span><span style="color:#953800;--shiki-dark:#FFA657"> HelloController</span><span style="color:#1F2328;--shiki-dark:#E6EDF3"> {</span></span>
<span class="line"><span style="color:#1F2328;--shiki-dark:#E6EDF3">    @</span><span style="color:#CF222E;--shiki-dark:#FF7B72">Get</span><span style="color:#1F2328;--shiki-dark:#E6EDF3"> </span><span style="color:#6E7781;--shiki-dark:#8B949E">// <i class="conum" data-value="2"></i></span></span>
<span class="line"><span style="color:#CF222E;--shiki-dark:#FF7B72">    String</span><span style="color:#8250DF;--shiki-dark:#D2A8FF"> index</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">() {</span></span>
<span class="line"><span style="color:#CF222E;--shiki-dark:#FF7B72">        return</span><span style="color:#0A3069;--shiki-dark:#A5D6FF"> "Hello World"</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">; </span><span style="color:#6E7781;--shiki-dark:#8B949E">// <i class="conum" data-value="3"></i></span></span>
<span class="line"><span style="color:#1F2328;--shiki-dark:#E6EDF3">    }</span></span>
<span class="line"><span style="color:#1F2328;--shiki-dark:#E6EDF3">}</span></span></code></pre>
    </div>
  </div>
  <div class="listingblock docs-code-block multi-language-sample" data-lang="kotlin">
    <div class="content">
      <pre class="shiki shiki-themes github-light-default github-dark-default" style="background-color:#ffffff;--shiki-dark-bg:#0d1117;color:#1f2328;--shiki-dark:#e6edf3" tabindex="0"><code class="language-kotlin shiki-code" data-lang="kotlin"><span class="line"><span style="color:#1F2328;--shiki-dark:#E6EDF3">@</span><span style="color:#CF222E;--shiki-dark:#FF7B72">Controller</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">(</span><span style="color:#0A3069;--shiki-dark:#A5D6FF">"/hello"</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">)</span></span>
<span class="line"><span style="color:#CF222E;--shiki-dark:#FF7B72">class</span><span style="color:#953800;--shiki-dark:#FFA657"> HelloController</span><span style="color:#1F2328;--shiki-dark:#E6EDF3"> {</span></span>
<span class="line"><span style="color:#1F2328;--shiki-dark:#E6EDF3">    @</span><span style="color:#CF222E;--shiki-dark:#FF7B72">Get</span></span>
<span class="line"><span style="color:#CF222E;--shiki-dark:#FF7B72">    fun</span><span style="color:#8250DF;--shiki-dark:#D2A8FF"> index</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">(): </span><span style="color:#953800;--shiki-dark:#FFA657">String</span><span style="color:#1F2328;--shiki-dark:#E6EDF3"> = </span><span style="color:#0A3069;--shiki-dark:#A5D6FF">"Hello World"</span></span>
<span class="line"><span style="color:#1F2328;--shiki-dark:#E6EDF3">}</span></span></code></pre>
    </div>
  </div>
  <div class="colist arabic">
    <table>
      <tr>
        <td><i class="conum" data-value="1"></i><b>1</b></td>
        <td>The <code>@Controller</code> annotation defines the class as a controller mapped to the path <code>/hello</code></td>
      </tr>
      <tr>
        <td><i class="conum" data-value="2"></i><b>2</b></td>
        <td>The <code>@Get</code> annotation maps the index method to all requests that use an HTTP GET</td>
      </tr>
      <tr>
        <td><i class="conum" data-value="3"></i><b>3</b></td>
        <td>A String <code>"Hello World"</code> is returned as the response</td>
      </tr>
    </table>
  </div>
</div>

<div data-snippet-fixture="generated-dependency">
  <div class="listingblock docs-code-block docs-code-dependency-snippet multi-language-sample" data-lang="gradle">
    <div class="title">HTTP client dependency</div>
    <div class="description">Gradle and Maven dependency variants rendered through the shared dependency snippet card.</div>
    <div class="content">
      <pre class="shiki shiki-themes github-light-default github-dark-default" style="background-color:#ffffff;--shiki-dark-bg:#0d1117;color:#1f2328;--shiki-dark:#e6edf3" tabindex="0"><code class="language-gradle shiki-code" data-lang="gradle"><span class="line"><span style="color:#8250DF;--shiki-dark:#D2A8FF">implementation</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">(</span><span style="color:#0A3069;--shiki-dark:#A5D6FF">"io.micronaut:micronaut-http-client"</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">)</span></span></code></pre>
    </div>
  </div>
  <div class="listingblock docs-code-block docs-code-dependency-snippet multi-language-sample" data-lang="maven">
    <div class="content">
      <pre class="shiki shiki-themes github-light-default github-dark-default" style="background-color:#ffffff;--shiki-dark-bg:#0d1117;color:#1f2328;--shiki-dark:#e6edf3" tabindex="0"><code class="language-maven shiki-code" data-lang="maven"><span class="line"><span style="color:#1F2328;--shiki-dark:#E6EDF3">&#x3C;</span><span style="color:#116329;--shiki-dark:#7EE787">dependency</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">></span></span>
<span class="line"><span style="color:#1F2328;--shiki-dark:#E6EDF3">    &#x3C;</span><span style="color:#116329;--shiki-dark:#7EE787">groupId</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">>io.micronaut&#x3C;/</span><span style="color:#116329;--shiki-dark:#7EE787">groupId</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">></span></span>
<span class="line"><span style="color:#1F2328;--shiki-dark:#E6EDF3">    &#x3C;</span><span style="color:#116329;--shiki-dark:#7EE787">artifactId</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">>micronaut-http-client&#x3C;/</span><span style="color:#116329;--shiki-dark:#7EE787">artifactId</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">></span></span>
<span class="line"><span style="color:#1F2328;--shiki-dark:#E6EDF3">&#x3C;/</span><span style="color:#116329;--shiki-dark:#7EE787">dependency</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">></span></span></code></pre>
    </div>
  </div>
</div>

<div data-snippet-fixture="generated-properties">
  <a id="generated-properties-anchor"></a>
  <table class="tableblock frame-all grid-all stretch">
    <caption>Table 1. Configuration Properties</caption>
    <thead>
      <tr><th>Property</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>micronaut.server.port</code></td><td>Server port used by the embedded application.</td></tr>
      <tr><td><code>micronaut.application.name</code></td><td>Application name exposed to framework integrations.</td></tr>
    </tbody>
  </table>
</div>
`;
---

<WebLayout
  title="Snippet Rendering Test"
  description="Component and generated-docs snippet rendering fixtures"
  surface="docs"
>
  <main class="border-b bg-background">
    <div class="mx-auto grid max-w-[var(--page-max)] gap-10 px-5 py-10 sm:px-6 xl:px-0">
      <header class="max-w-3xl">
        <Badge variant="secondary" className="mb-4">Internal visual test</Badge>
        <h1 class="text-3xl font-bold tracking-tight md:text-4xl">Snippet Rendering Test</h1>
        <p class="mt-3 text-base leading-7 text-muted-foreground">
          This page renders the shared React snippet components and compares them against an offscreen generated-docs fixture.
        </p>
      </header>

      <section class="grid gap-6">
        <div>
          <h2 class="text-2xl font-semibold tracking-tight">Component path</h2>
          <p class="mt-1 text-sm leading-6 text-muted-foreground">
            These snippets are rendered directly through the reusable React components.
          </p>
        </div>
        <SnippetTestGallery highlightedHtmlByKey={snippetTestHighlightedHtmlByKey} client:load />
      </section>

      <section class="sr-only" aria-hidden="true">
        <h2>Generated docs validation fixture</h2>
      </section>
      <div class="pointer-events-none absolute left-0 top-0 -z-10 w-[960px] opacity-0" aria-hidden="true">
        <div class="generated-docs-content grid gap-8" data-generated-docs set:html={generatedDocsFixture} />
      </div>
      <GeneratedDocsEnhancer />
      <GeneratedDocsPropertiesFallback />
    </div>
  </main>
</WebLayout>
