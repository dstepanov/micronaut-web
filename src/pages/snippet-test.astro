<span class="line"><span style="color:#1F2328;--shiki-dark:#E6EDF3">    &#x3C;</span><span style="color:#116329;--shiki-dark:#7EE787">groupId</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">>io.micronaut&#x3C;/</span><span style="color:#116329;--shiki-dark:#7EE787">groupId</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">></span></span>
<span class="line"><span style="color:#1F2328;--shiki-dark:#E6EDF3">    &#x3C;</span><span style="color:#116329;--shiki-dark:#7EE787">artifactId</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">>micronaut-http-client&#x3C;/</span><span style="color:#116329;--shiki-dark:#7EE787">artifactId</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">></span></span>
<span class="line"><span style="color:#1F2328;--shiki-dark:#E6EDF3">&#x3C;/</span><span style="color:#116329;--shiki-dark:#7EE787">dependency</span><span style="color:#1F2328;--shiki-dark:#E6EDF3">></span></span></code></pre>
    </div>
  </div>
</div>

<div data-snippet-fixture="generated-properties">
  <a id="generated-properties-anchor"></a>
  <table class="tableblock frame-all grid-all stretch">
    <caption>Table 1. Configuration Properties</caption>
    <thead>
      <tr><th>Property</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>micronaut.server.port</code></td><td>Server port used by the embedded application.</td></tr>
      <tr><td><code>micronaut.application.name</code></td><td>Application name exposed to framework integrations.</td></tr>
    </tbody>
  </table>
</div>
`;
---

<WebLayout
  title="Snippet Rendering Test"
  description="Component and generated-docs snippet rendering fixtures"
  surface="docs"
>
  <main class="border-b bg-background">
    <div class="mx-auto grid max-w-[var(--page-max)] gap-10 px-5 py-10 sm:px-6 xl:px-0">
      <header class="max-w-3xl">
        <Badge variant="secondary" className="mb-4">Internal visual test</Badge>
        <h1 class="text-3xl font-bold tracking-tight md:text-4xl">Snippet Rendering Test</h1>
        <p class="mt-3 text-base leading-7 text-muted-foreground">
          This page renders the shared React snippet components and compares them against an offscreen generated-docs fixture.
        </p>
      </header>

      <section class="grid gap-6">
        <div>
          <h2 class="text-2xl font-semibold tracking-tight">Component path</h2>
          <p class="mt-1 text-sm leading-6 text-muted-foreground">
            These snippets are rendered directly through the reusable React components.
          </p>
        </div>
        <SnippetTestGallery highlightedHtmlByKey={snippetTestHighlightedHtmlByKey} client:visible />
      </section>

      <section class="sr-only" aria-hidden="true">
        <h2>Generated docs validation fixture</h2>
      </section>
      <div class="pointer-events-none absolute left-0 top-0 -z-10 w-[960px] opacity-0" aria-hidden="true">
        <div class="generated-docs-content grid gap-8" data-generated-docs set:html={generatedDocsFixture} />
      </div>
      <GeneratedDocsEnhancer />

      <section class="rounded-xl border bg-card p-5 text-sm" data-snippet-validation>
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <h2 class="text-base font-semibold">Runtime validation</h2>
            <p class="mt-1 text-muted-foreground">Checks generated docs snippets against the component-rendered reference.</p>
          </div>
          <Badge variant="outline" data-snippet-validation-status>Waiting</Badge>
        </div>
        <ul class="mt-4 grid gap-2 text-muted-foreground" data-snippet-validation-list>
          <li>Waiting for snippets to render.</li>
        </ul>
      </section>
    </div>
  </main>
</WebLayout>

<script is:inline>
  (() => {
    const validationRoot = document.querySelector("[data-snippet-validation]");
    const status = validationRoot?.querySelector("[data-snippet-validation-status]");
    const list = validationRoot?.querySelector("[data-snippet-validation-list]");

    const readStyle = (element, property) => element ? getComputedStyle(element)[property] : "";
    const readPseudoStyle = (element, pseudo, property) => element ? getComputedStyle(element, pseudo)[property] : "";
    const rgb = (value) => (value.match(/\d+(?:\.\d+)?/g) || []).slice(0, 3).map(Number);
    const isLight = (value) => {
      const [red = 0, green = 0, blue = 0] = rgb(value);
      return (red + green + blue) / 3 > 238;
    };

    const pushResult = (results, ok, label, detail = "") => {
      results.push({ ok, label, detail });
    };

    const compareStyle = (results, label, left, right, property) => {
      const leftValue = readStyle(left, property);
      const rightValue = readStyle(right, property);
      pushResult(results, leftValue === rightValue, label, `${leftValue} / ${rightValue}`);
    };

    const renderResults = (results) => {
      if (!status || !list) {
        return;
      }
      const failed = results.filter((result) => !result.ok);
      status.textContent = failed.length ? `${failed.length} failed` : "Passed";
      status.dataset.state = failed.length ? "failed" : "passed";
      status.classList.toggle("border-destructive", failed.length > 0);
      status.classList.toggle("text-destructive", failed.length > 0);
      status.classList.toggle("border-brand/40", failed.length === 0);
      status.classList.toggle("text-brand", failed.length === 0);
      document.documentElement.dataset.snippetTestStatus = failed.length ? "failed" : "passed";
      list.replaceChildren(
        ...results.map((result) => {
          const item = document.createElement("li");
          item.className = result.ok ? "text-muted-foreground" : "text-destructive";
          item.textContent = `${result.ok ? "Pass" : "Fail"}: ${result.label}${result.detail ? ` (${result.detail})` : ""}`;
          return item;
        })
      );
    };

    const runValidation = () => {
      const results = [];
      const componentCard = document.querySelector("[data-snippet-fixture='component-code'] .docs-snippet-template");
      const generatedCard = document.querySelector("[data-snippet-fixture='generated-multi'] .docs-snippet-template");
      const componentHeader = componentCard?.querySelector(".docs-code-toolbar");
      const generatedHeader = generatedCard?.querySelector(".docs-code-toolbar");
      const componentContent = componentCard?.querySelector(".docs-snippet-panels");
      const generatedContent = generatedCard?.querySelector(".docs-snippet-panels");
      const componentPre = componentCard?.querySelector("pre.shiki");
      const generatedPre = generatedCard?.querySelector("pre.shiki");
      const componentCopy = componentCard?.querySelector(".docs-code-copy");
      const generatedCopy = generatedCard?.querySelector(".docs-code-copy");
      const generatedFooter = generatedCard?.querySelector(".docs-code-callouts");
      const generatedTableCallout = generatedFooter?.querySelector("td:first-child .conum");
      const generatedTableCalloutFallback = generatedFooter?.querySelector("td:first-child .conum + b");
      const componentDependencyHeader = document.querySelector("[data-snippet-fixture='component-dependency'] .docs-snippet-external-header");
      const componentDependency = document.querySelector("[data-snippet-fixture='component-dependency'] .docs-dependency-template");
      const componentDependencyGradleIcon = componentDependency?.querySelector(".docs-code-language-icon-gradle");
      const generatedDependency = document.querySelector("[data-snippet-fixture='generated-dependency'] .docs-dependency-template");
      const generatedDependencyHeader = document.querySelector("[data-snippet-fixture='generated-dependency'] .docs-snippet-external-header");
      const generatedDependencyGradleIcon = generatedDependency?.querySelector(".docs-code-language-icon-gradle");
      const generatedProperties = document.querySelector("[data-snippet-fixture='generated-properties'] .docs-properties-template");

      pushResult(results, Boolean(componentCard), "component code card rendered");
      pushResult(results, Boolean(generatedCard), "generated multi-language card enhanced");
      pushResult(results, Boolean(generatedDependency), "generated dependency card enhanced");
      pushResult(results, Boolean(generatedProperties), "generated properties table enhanced");
      pushResult(results, Boolean(componentPre?.querySelector("span[style*='--shiki-dark']")), "component code uses Shiki token spans");
      pushResult(results, Boolean(componentCopy?.classList.contains("docs-snippet-copy") && generatedCopy?.classList.contains("docs-snippet-copy")), "copy buttons use the shared marker class");
      pushResult(results, Boolean(componentDependencyHeader), "component dependency title is outside the card");
      pushResult(results, Boolean(componentDependency && !componentDependency.querySelector(".docs-snippet-heading")), "component dependency card has toolbar-only header");
      pushResult(results, Boolean(componentDependencyGradleIcon), "component dependency Gradle tab has an icon");
      pushResult(results, Boolean(generatedDependencyHeader), "generated dependency title is outside the card");
      pushResult(results, Boolean(generatedDependency && !generatedDependency.querySelector(".docs-snippet-heading")), "generated dependency card has toolbar-only header");
      pushResult(results, Boolean(generatedDependencyGradleIcon), "generated dependency Gradle tab has an icon");

      compareStyle(results, "card background matches", componentCard, generatedCard, "backgroundColor");
      compareStyle(results, "card border color matches", componentCard, generatedCard, "borderTopColor");
      compareStyle(results, "toolbar background matches", componentHeader, generatedHeader, "backgroundColor");
      compareStyle(results, "content background matches", componentContent, generatedContent, "backgroundColor");
      compareStyle(results, "code background matches", componentPre, generatedPre, "backgroundColor");
      compareStyle(results, "copy button color matches", componentCopy, generatedCopy, "color");
      pushResult(results, isLight(readStyle(generatedPre, "backgroundColor")), "generated code panel is light", readStyle(generatedPre, "backgroundColor"));
      pushResult(results, isLight(readStyle(generatedHeader, "backgroundColor")), "generated toolbar is light", readStyle(generatedHeader, "backgroundColor"));
      pushResult(results, readPseudoStyle(generatedTableCallout, "::before", "content") === "\"1\"", "table callout badge renders data-value");
      pushResult(results, readStyle(generatedTableCalloutFallback, "display") === "none", "table callout fallback number is hidden");
      pushResult(results, readStyle(generatedTableCallout, "color") === readStyle(generatedPre, "backgroundColor"), "table callout badge keeps white number on dark badge");

      renderResults(results);
    };

    const scheduleValidation = () => {
      requestAnimationFrame(() => window.setTimeout(runValidation, 0));
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", scheduleValidation, { once: true });
    } else {
      scheduleValidation();
    }
    document.addEventListener("astro:page-load", scheduleValidation);
  })();
</script>
