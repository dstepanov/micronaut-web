---
import WebLayout from "@/layouts/WebLayout.astro";
import { Badge } from "@/components/ui/badge";
import {
  Card,
  CardAction,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle
} from "@/components/ui/card";
import { ActionLink } from "@/components/web/action-link";
import { IconGlyph } from "@/components/web/icon-glyph";
import { MainCodeShowcase } from "@/components/web/main-code-showcase";
import SiteFooter from "@/components/web/site-footer.astro";
import { withBasePath } from "@/lib/base-path";
import { highlightCodeSnippetExamples } from "@/lib/docs-code-highlighting";
import { getMainCodeShowcaseExamples } from "@/lib/main-code-showcase-content";
import { getSuccessStories } from "@/lib/main-site-content";

const features = [
  {
    title: "Compile-time dependency injection",
    icon: "feature:aspect-oriented-api",
    copy: "Generate dependency metadata at build time and reduce runtime reflection.",
    proof: "Build-time bean graph",
    chip: "@Singleton -> BeanDefinition",
    accentClass: "bg-mn-cyan/10 text-mn-cyan",
    chipClass: "border-mn-cyan/25 bg-mn-cyan/10 text-mn-cyan",
    href: "/docs/core/",
    priority: true
  },
  {
    title: "Fast startup and low memory",
    icon: "feature:aot-compilation",
    copy: "Designed for lean services, serverless functions, and native images.",
    proof: "Lean startup path",
    chip: "native-image ready",
    accentClass: "bg-mn-red/10 text-mn-red",
    chipClass: "border-mn-red/25 bg-mn-red/10 text-mn-red",
    href: "/docs/aot/",
    priority: true
  },
  {
    title: "Cloud-native by default",
    icon: "feature:natively-cloud-native",
    copy: "Service discovery, tracing, configuration, and cloud runtime support.",
    proof: "Runtime integrations",
    chip: "K8s + tracing + config",
    accentClass: "bg-mn-cyan/10 text-mn-cyan",
    chipClass: "border-mn-cyan/25 bg-mn-cyan/10 text-mn-cyan",
    href: "/docs/kubernetes/",
    priority: true
  },
  {
    title: "Built-in testing support",
    icon: "feature:fast-easy-testing",
    copy: "Start tests quickly with dependency injection and application context support.",
    proof: "App-context tests",
    chip: "@MicronautTest",
    accentClass: "bg-mn-green/10 text-mn-green",
    chipClass: "border-mn-green/25 bg-mn-green/10 text-mn-green",
    href: "/docs/test/",
    priority: true
  },
  {
    title: "HTTP server and client",
    icon: "feature:smooth-learning-curve",
    copy: "Create controllers and declarative clients with familiar annotations.",
    proof: "Shared route model",
    chip: "@Controller / @Client",
    accentClass: "bg-mn-cyan/10 text-mn-cyan",
    chipClass: "border-mn-cyan/25 bg-mn-cyan/10 text-mn-cyan",
    href: "/docs/core/"
  },
  {
    title: "Micronaut Data",
    icon: "feature:fast-data-config",
    copy: "Repository APIs that avoid runtime model scanning.",
    proof: "Compile-time queries",
    chip: "Repository<T, ID>",
    accentClass: "bg-mn-cyan/10 text-mn-cyan",
    chipClass: "border-mn-cyan/25 bg-mn-cyan/10 text-mn-cyan",
    href: "/docs/data/"
  },
  {
    title: "OpenAPI Visibility",
    icon: "feature:seamless-api-visibility",
    copy: "Keep service contracts discoverable and documented.",
    proof: "Contract-first clarity",
    chip: "OpenAPI metadata",
    accentClass: "bg-mn-cyan/10 text-mn-cyan",
    chipClass: "border-mn-cyan/25 bg-mn-cyan/10 text-mn-cyan",
    href: "/docs/openapi/"
  },
  {
    title: "Java, Kotlin, and Groovy",
    icon: "feature:polyglot-framework",
    copy: "Use the JVM language that fits your team.",
    proof: "JVM language choice",
    chip: "Java / Kotlin / Groovy",
    accentClass: "bg-mn-cyan/10 text-mn-cyan",
    chipClass: "border-mn-cyan/25 bg-mn-cyan/10 text-mn-cyan",
    href: "/learn/"
  }
];

const cloudLogos = [
  { label: "Kubernetes", icon: "brand:kubernetes" },
  { label: "Oracle Cloud", icon: "brand:oracle" },
  { label: "OpenTelemetry", icon: "brand:opentelemetry" },
  { label: "Apache Kafka", icon: "brand:apachekafka" },
  { label: "Redis", icon: "brand:redis" },
  { label: "MongoDB", icon: "brand:mongodb" }
];

const assetDimensions: Record<string, { width: number; height: number }> = {
  "/micronaut-assets/main-site/wp-content/uploads/2025/01/Agorapulse-logo-blue.svg": { width: 1204, height: 251 },
  "/micronaut-assets/main-site/wp-content/uploads/2025/01/Kestra.full_.logo_.dark_.svg": { width: 889, height: 203 },
  "/micronaut-assets/home/minecraft.png": { width: 429, height: 185 },
  "/micronaut-assets/home/mojang.png": { width: 387, height: 185 },
  "/micronaut-assets/home/samsung-smart-things.png": { width: 429, height: 185 },
  "/micronaut-assets/home/sonar-black-and-grey.svg": { width: 224, height: 86 },
  "/micronaut-assets/home/target.png": { width: 142, height: 185 }
};

const dimensionsForAsset = (assetPath?: string) => assetPath ? assetDimensions[assetPath] : undefined;

const stories = (await getSuccessStories()).map((story) => ({
  ...story,
  logo: story.logo ? withBasePath(story.logo) : undefined,
  logoDimensions: dimensionsForAsset(story.logo)
}));
const featuredStories = stories.slice(0, 3);
const secondaryStories = stories.slice(3);

const storyLogoItems = stories
  .filter((story) => story.logo)
  .map((story) => ({
    name: story.organization,
    href: withBasePath(story.href),
    image: story.logo ?? "",
    className: story.logoClass,
    width: story.logoDimensions?.width,
    height: story.logoDimensions?.height,
    logoInvertOnDark: story.logoInvertOnDark
  }));

const previousCustomerLogos = [
  { name: "Minecraft", href: "https://www.minecraft.net/", image: withBasePath("/micronaut-assets/home/minecraft.png"), className: "h-12", width: 429, height: 185, logoInvertOnDark: false },
  { name: "Mojang", href: "https://en.wikipedia.org/wiki/Mojang_Studios", image: withBasePath("/micronaut-assets/home/mojang.png"), className: "h-12", width: 387, height: 185, logoInvertOnDark: false },
  { name: "Target", href: "https://www.target.com", image: withBasePath("/micronaut-assets/home/target.png"), className: "h-16", width: 142, height: 185, logoInvertOnDark: false }
];
const whoUsesLogoItems = [...storyLogoItems, ...previousCustomerLogos];
const rotatingLogoItems = [...whoUsesLogoItems, ...whoUsesLogoItems];

const graalBullets = ["Ahead-of-time friendly", "Reduced reflection reliance", "Native-image deployment path"];
const dataBullets = ["Repository APIs", "Compile-time query model", "Reduced runtime overhead"];
const cloudBullets = ["Service discovery", "Distributed tracing", "Cloud runtimes", "Messaging and data integrations"];
const codeProofs = ["Same annotations across server and client", "Compile-time metadata generation", "Fast tests with application context support"];
const highlightedCodeShowcaseExamples = await highlightCodeSnippetExamples(await getMainCodeShowcaseExamples());
---

<WebLayout
  title="Micronaut Framework | Runtime Console Theme"
  description="A modern, JVM-based, full-stack framework for building modular, easily testable microservice and serverless applications"
  surface="main"
  theme="runtime"
>
  <main>
    <section class="relative isolate overflow-hidden border-b border-mn-border bg-mn-bg text-mn-text">
      <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_right,rgb(20_32_51/.06)_1px,transparent_1px),linear-gradient(to_bottom,rgb(20_32_51/.06)_1px,transparent_1px)] bg-[size:44px_44px] opacity-55"></div>
      <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(135deg,rgb(16_137_175/.14),transparent_34%,rgb(112_86_217/.11)_68%,rgb(210_68_52/.1))]"></div>
      <div class="relative mx-auto grid max-w-[var(--page-max)] gap-12 px-5 py-[var(--runtime-hero-y)] sm:px-6 lg:grid-cols-[minmax(0,1fr)_minmax(380px,500px)] lg:items-center xl:px-0">
        <div class="max-w-[720px]">
          <Badge variant="outline" className="mb-5 border-mn-border bg-mn-surface/75 px-3 py-1.5 text-xs text-mn-muted shadow-sm backdrop-blur">
            High-performance cloud runtime for the JVM
          </Badge>
          <h1 class="max-w-[700px] text-[2.4rem] font-extrabold leading-[1.04] text-mn-text sm:text-[2.9rem] md:text-[3.85rem]">
            Launch fast cloud applications without runtime framework drag
          </h1>
          <p class="mt-5 max-w-[580px] text-[1.05rem] leading-8 text-mn-muted md:text-[1.1rem]">
            Micronaut moves dependency injection, AOP, and metadata work to compilation so microservices, serverless functions, and native images start lean.
          </p>
          <div class="mt-6 flex flex-wrap gap-2.5">
            <Badge variant="outline" className="border-mn-cyan/25 bg-mn-surface/80 px-3 py-1.5 text-xs text-mn-cyan">Compile-time DI</Badge>
            <Badge variant="outline" className="border-mn-cyan/25 bg-mn-surface/80 px-3 py-1.5 text-xs text-mn-cyan">No runtime reflection</Badge>
            <Badge variant="outline" className="border-mn-green/25 bg-mn-surface/80 px-3 py-1.5 text-xs text-mn-green">GraalVM native ready</Badge>
          </div>
          <div class="mt-7 flex flex-wrap gap-3">
            <ActionLink href="/launch/" label="Launch a project" size="lg" className="bg-mn-red text-mn-bg shadow-glow hover:bg-mn-red/90" />
            <ActionLink href="/docs/" label="View documentation" size="lg" variant="secondary" className="bg-mn-surface-raised text-mn-text hover:bg-mn-surface" />
            <ActionLink href="/guides/" label="Browse guides" size="lg" variant="outline" className="border-mn-border bg-mn-surface/65 text-mn-text hover:bg-mn-surface-raised" />
          </div>
          <div class="mt-8 grid max-w-[560px] gap-3 sm:grid-cols-3">
            <div class="rounded-card border border-mn-border bg-mn-surface/75 p-3 shadow-sm backdrop-blur">
              <p class="font-mono text-xs text-mn-red">01</p>
              <p class="mt-1 text-sm font-semibold text-mn-text">Analyze annotations</p>
            </div>
            <div class="rounded-card border border-mn-border bg-mn-surface/75 p-3 shadow-sm backdrop-blur">
              <p class="font-mono text-xs text-mn-cyan">02</p>
              <p class="mt-1 text-sm font-semibold text-mn-text">Generate metadata</p>
            </div>
            <div class="rounded-card border border-mn-border bg-mn-surface/75 p-3 shadow-sm backdrop-blur">
              <p class="font-mono text-xs text-mn-green">03</p>
              <p class="mt-1 text-sm font-semibold text-mn-text">Run lean</p>
            </div>
          </div>
          <a href={withBasePath("/guides/creating-your-first-micronaut-app/")} class="mt-5 inline-flex text-sm font-medium text-mn-cyan underline-offset-4 hover:underline">
            New to Micronaut? Start with the quickstart -&gt;
          </a>
        </div>

        <div class="relative">
          <div class="absolute -inset-3 -z-10 rounded-card bg-[linear-gradient(135deg,rgb(210_68_52/.16),rgb(16_137_175/.12),rgb(112_86_217/.14))] blur-xl"></div>
          <div class="overflow-hidden rounded-card border border-mn-border bg-mn-surface shadow-console">
            <div class="flex items-center gap-3 border-b border-mn-border bg-mn-surface-raised px-4 py-3">
              <div class="flex gap-1.5" aria-hidden="true">
                <span class="size-2.5 rounded-full bg-mn-red"></span>
                <span class="size-2.5 rounded-full bg-mn-cyan"></span>
                <span class="size-2.5 rounded-full bg-mn-green"></span>
              </div>
              <div class="min-w-0 flex-1 truncate font-mono text-xs text-mn-muted">micronaut-runtime-console</div>
              <IconGlyph name="terminal" className="size-4 text-mn-muted" />
            </div>
            <div class="grid gap-5 p-5">
              <div class="rounded-lg border border-slate-800 bg-slate-950 p-4 font-mono text-xs leading-6 text-slate-100">
                <p><span class="text-mn-green">$</span> mn create-app hello-runtime --features=http-client,graalvm</p>
                <p class="mt-3 text-slate-400">Resolving build-time bean metadata...</p>
                <p class="text-slate-400">Generating AOP and route definitions...</p>
                <p class="text-mn-green">Application scaffolded with native-image support.</p>
              </div>
              <div class="grid gap-3">
                {[
                  { label: "Annotations", value: "@Controller @Inject", color: "text-mn-red" },
                  { label: "Compile-time metadata", value: "BeanDefinition[]", color: "text-mn-cyan" },
                  { label: "Lean runtime", value: "No classpath scanning", color: "text-mn-violet" },
                  { label: "Deploy target", value: "JVM / Native / Serverless", color: "text-mn-green" }
                ].map((step, index) => (
                  <div class="grid grid-cols-[32px_minmax(0,1fr)] items-start gap-3 rounded-lg border border-mn-border bg-mn-bg/70 p-3">
                    <span class={`grid size-8 place-items-center rounded-md bg-mn-surface-raised font-mono text-xs font-semibold shadow-sm ${step.color}`}>
                      {index + 1}
                    </span>
                    <div class="min-w-0">
                      <p class="text-sm font-semibold text-mn-text">{step.label}</p>
                      <p class="mt-0.5 truncate font-mono text-xs text-mn-muted">{step.value}</p>
                    </div>
                  </div>
                ))}
              </div>
              <div class="grid grid-cols-3 gap-2 text-center">
                <div class="rounded-lg border border-mn-border bg-mn-surface-raised p-3">
                  <p class="font-mono text-sm font-semibold text-mn-red">DI</p>
                  <p class="mt-1 text-[0.7rem] leading-4 text-mn-muted">compile-time</p>
                </div>
                <div class="rounded-lg border border-mn-border bg-mn-surface-raised p-3">
                  <p class="font-mono text-sm font-semibold text-mn-cyan">AOT</p>
                  <p class="mt-1 text-[0.7rem] leading-4 text-mn-muted">native path</p>
                </div>
                <div class="rounded-lg border border-mn-border bg-mn-surface-raised p-3">
                  <p class="font-mono text-sm font-semibold text-mn-green">HTTP</p>
                  <p class="mt-1 text-[0.7rem] leading-4 text-mn-muted">server/client</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-mn-border bg-[linear-gradient(180deg,var(--mn-surface),var(--mn-bg))]">
      <div class="mx-auto grid max-w-[var(--page-max)] gap-7 px-5 py-[var(--section-y)] sm:px-6 xl:px-0">
        <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <div class="min-w-0">
            <Badge variant="outline" className="border-mn-border bg-mn-surface-raised text-mn-muted">Capability system</Badge>
            <h2 class="mt-4 max-w-[520px] text-3xl font-bold text-mn-text md:text-4xl">The runtime advantages are visible in every layer</h2>
          </div>
          <p class="max-w-[560px] text-base leading-7 text-mn-muted">
            Compile-time APIs, native-image readiness, integrated testing, cloud support, and productive data access work together instead of competing for attention.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {features.map((feature) => (
            <a
              href={withBasePath(feature.href)}
              class="group rounded-card outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50"
              aria-label={`${feature.title}: ${feature.copy}`}
            >
              <Card className={`h-full min-h-[236px] overflow-hidden border-mn-border bg-mn-surface/95 shadow-sm shadow-slate-950/[0.04] transition group-hover:-translate-y-1 group-hover:border-mn-cyan/45 group-hover:shadow-console ${feature.priority ? "ring-1 ring-mn-cyan/15" : ""}`}>
                <CardHeader className="gap-4">
                  <div class="flex items-start justify-between gap-3">
                    <span class={`grid size-12 shrink-0 place-items-center rounded-lg ${feature.accentClass}`}>
                      <IconGlyph name={feature.icon} className="size-8" />
                    </span>
                    <span class="rounded-full border border-mn-border bg-mn-bg px-2.5 py-1 text-right text-[0.68rem] font-semibold uppercase tracking-wide text-mn-muted">
                      {feature.proof}
                    </span>
                  </div>
                  <div>
                    <CardTitle className="text-[1rem] leading-6 text-mn-text">{feature.title}</CardTitle>
                    <CardDescription className="mt-2 text-[0.92rem] text-mn-muted">{feature.copy}</CardDescription>
                  </div>
                </CardHeader>
                <CardContent className="mt-auto">
                  <span class={`inline-flex max-w-full rounded-md border px-2.5 py-1 font-mono text-[0.72rem] leading-4 ${feature.chipClass}`}>
                    {feature.chip}
                  </span>
                </CardContent>
                <CardFooter className="pt-0">
                  <span class="text-sm font-medium text-mn-cyan transition group-hover:text-mn-red group-focus-visible:text-mn-red">
                    Explore capability -&gt;
                  </span>
                </CardFooter>
              </Card>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-mn-border bg-mn-bg">
      <div class="mx-auto grid max-w-[var(--page-max)] gap-10 px-5 py-[var(--section-y)] sm:px-6 lg:grid-cols-[340px_minmax(0,1fr)] xl:px-0">
        <div>
          <Badge variant="outline" className="border-mn-border bg-mn-surface text-mn-muted">IDE workflow</Badge>
          <h2 class="mt-4 text-3xl font-bold text-mn-text md:text-4xl">Build an endpoint, client, and test with one model</h2>
          <p class="mt-4 text-base leading-7 text-mn-muted">
            Define a controller, create a declarative HTTP client, and test both using the same compact application model.
          </p>
          <div class="mt-6 grid gap-3 text-sm leading-6 text-mn-muted">
            {codeProofs.map((item) => (
              <div class="flex items-start gap-2">
                <IconGlyph name="check-circle" className="mt-1 size-4 shrink-0 text-mn-green" />
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>
        <MainCodeShowcase examples={highlightedCodeShowcaseExamples} variant="runtime" client:load />
      </div>
    </section>

    <section class="border-b border-mn-border bg-[linear-gradient(180deg,var(--mn-bg),var(--mn-surface))] text-mn-text">
      <div class="mx-auto grid max-w-[var(--page-max)] gap-7 px-5 py-[var(--section-y)] sm:px-6 xl:px-0">
      <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
          <Badge variant="outline" className="border-mn-border bg-mn-surface-raised text-mn-muted">Who uses Micronaut?</Badge>
          <h2 class="mt-4 text-3xl font-bold md:text-4xl">Who&rsquo;s using The Micronaut Framework?</h2>
          <p class="mt-4 max-w-2xl text-base leading-7 text-mn-muted">
            See how Micronaut users are achieving results with the Micronaut framework across serverless APIs, migrations, workflow platforms, and cloud services.
          </p>
        </div>
        <ActionLink href="/micronaut-success-stories/" label="View all success stories" variant="outline" className="border-mn-border bg-mn-surface text-mn-text hover:bg-mn-surface-raised" />
      </div>

      <div class="grid gap-4 lg:grid-cols-3">
        {featuredStories.map((story) => (
          <Card className="h-full min-h-[260px] border-mn-border bg-mn-surface/95 text-mn-text shadow-console transition hover:-translate-y-0.5 hover:border-mn-cyan/45">
            <CardHeader>
              {story.logo ? (
                <div class="flex h-16 min-w-0 items-center">
                  <span class="inline-flex h-14 max-w-[12rem] items-center rounded-md border border-mn-border bg-mn-surface-raised px-3 py-2 shadow-sm">
                    <img src={story.logo} alt={`${story.organization} logo`} class:list={["max-h-full max-w-full object-contain object-left", story.logoClass, story.logoInvertOnDark && "dark:brightness-0 dark:invert"]} loading="lazy" width={story.logoDimensions?.width} height={story.logoDimensions?.height} />
                  </span>
                </div>
              ) : null}
              <CardAction className="row-span-1">
                <Badge variant="secondary" className="bg-mn-bg text-mn-muted">{story.tag}</Badge>
              </CardAction>
              <CardTitle className="col-span-full text-xl leading-7">{story.title}</CardTitle>
              <CardDescription className="col-span-full text-[0.94rem] text-mn-muted">{story.summary}</CardDescription>
            </CardHeader>
            <CardContent>
              <div class="flex flex-wrap gap-2">
                {story.proofs?.map((proof) => (
                  <Badge variant="outline" className="border-mn-border bg-mn-bg text-xs text-mn-muted">{proof}</Badge>
                ))}
              </div>
            </CardContent>
            <CardFooter className="mt-auto">
              <ActionLink href={story.href} label="Read story ->" variant="ghost" className="-ml-3 text-mn-cyan hover:bg-mn-surface-raised hover:text-mn-red" />
            </CardFooter>
          </Card>
        ))}
      </div>
      <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-4">
        {secondaryStories.map((story) => (
          <a href={withBasePath(story.href)} class="group rounded-xl outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50">
            <Card className="h-full gap-4 border-mn-border bg-mn-surface/95 py-5 text-mn-text transition group-hover:-translate-y-0.5 group-hover:border-mn-cyan/45 group-hover:shadow-console">
              <CardHeader className="gap-3 px-5">
                {story.logo ? (
                  <span class="inline-flex h-11 max-w-[10rem] items-center rounded-md border border-mn-border bg-mn-surface-raised px-3 py-2 shadow-sm">
                    <img src={story.logo} alt={`${story.organization} logo`} class:list={["max-h-full max-w-full object-contain object-left", story.logoClass, story.logoInvertOnDark && "dark:brightness-0 dark:invert"]} loading="lazy" width={story.logoDimensions?.width} height={story.logoDimensions?.height} />
                  </span>
                ) : null}
                <CardAction className="row-span-1">
                  <Badge variant="outline" className="border-mn-border bg-mn-bg text-mn-muted">{story.tag}</Badge>
                </CardAction>
                <CardTitle className="col-span-full text-[1rem] leading-6">{story.organization}</CardTitle>
                <CardDescription className="col-span-full text-[0.9rem] text-mn-muted">{story.summary}</CardDescription>
              </CardHeader>
              <CardFooter className="mt-auto px-5">
                <span class="text-sm font-medium text-mn-cyan transition group-hover:text-mn-red">Read story -&gt;</span>
              </CardFooter>
            </Card>
          </a>
        ))}
      </div>
      <div class="customer-logo-marquee relative -mx-5 overflow-hidden border-y border-mn-border bg-mn-surface py-6 shadow-inner shadow-black/[0.06] sm:-mx-6 xl:mx-0 xl:rounded-lg xl:border">
        <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-16 bg-linear-to-r from-mn-surface to-transparent sm:w-24"></div>
        <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-16 bg-linear-to-l from-mn-surface to-transparent sm:w-24"></div>
        <div class="customer-logo-track flex w-max gap-3 px-3">
          {rotatingLogoItems.map((customer, index) => (
            <a
              href={customer.href}
              class="group flex h-20 w-[12.5rem] shrink-0 items-center justify-center rounded-md border border-mn-border bg-mn-surface-raised px-5 shadow-sm transition hover:border-mn-cyan/50 hover:shadow-md"
              aria-label={`${customer.name}${index >= whoUsesLogoItems.length ? " duplicate" : ""}`}
              aria-hidden={index >= whoUsesLogoItems.length ? "true" : undefined}
              tabindex={index >= whoUsesLogoItems.length ? "-1" : undefined}
            >
              <img
                src={customer.image}
