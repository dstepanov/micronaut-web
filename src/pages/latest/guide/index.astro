---
import { withBasePath } from "@/lib/base-path";
import { routeCompatibilityEntry } from "@/lib/route-compatibility";

const compatibility = routeCompatibilityEntry("docs-core-latest-guide");
const destination = withBasePath(compatibility.previewDestinationPath);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0;url=${destination}`} />
    <title>Redirecting to Micronaut Core docs</title>
    <script is:inline define:vars={{ destination }}>
      (() => {
        const suffix = `${window.location.search}${window.location.hash}`;
        window.location.replace(`${destination}${suffix}`);
      })();
    </script>
  </head>
  <body>
    <a href={destination}>Continue to Micronaut Core docs</a>
  </body>
</html>
